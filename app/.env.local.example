# app/.env.local.example
#
# Copy this file to app/.env.local and fill in all values.
# This file is safe to commit; .env.local is gitignored.

# ── Google OAuth (NextAuth) ──────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Public URL of the app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# ── Gmail API (automated report ingestion) ───────────────────────────
# Path to the Google Workspace service account JSON file (mounted as Docker volume)
GMAIL_SERVICE_ACCOUNT_PATH=/app/config/service-account.json
# Google Workspace user to impersonate via domain-wide delegation
GMAIL_IMPERSONATE_EMAIL=you@example.com
# Secret used to authenticate cron-triggered import calls
AUTO_IMPORT_API_KEY=

# ── GitHub App (in-app feedback → GitHub Issues) ─────────────────────────────
# Create a GitHub App at https://github.com/settings/apps
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
...
-----END RSA PRIVATE KEY-----"
GITHUB_INSTALLATION_ID=

# ── FileMaker Data API ────────────────────────────────────────────────────────
FM_API_BASE=
FM_USERNAME=
FM_PASSWORD=

# ── Mailchimp ─────────────────────────────────────────────────────────────────
MAILCHIMP_API_KEY=

# ── Axper (store traffic) ─────────────────────────────────────────────────────
NEXT_PUBLIC_AXPER_API_URL=https://api.axper.com/v1
AXPER_API_KEY=

# ── PBX / Phone System ────────────────────────────────────────────────────────
PBX_API_URL=
PBX_API_TOKEN_URL=
PBX_API_CLIENT_ID=
PBX_API_CLIENT_SECRET=

# ── MDM (Mobile Device Management) ───────────────────────────────────────────
MDM_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional per-deployment web-font stylesheet (e.g. an Adobe Typekit kit URL).
# Omitted entirely when unset -> system/web-safe fonts. Each deploy sets its OWN.
NEXT_PUBLIC_FONT_CSS_URL=

# Set to "true" only when the app sits behind a single trusted reverse proxy
# (e.g. nginx). Lets the rate limiter use the proxy-appended client IP. Leave
# unset when the app is reachable directly (X-Forwarded-For is then ignored).
TRUST_PROXY=
