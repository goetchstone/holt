{
  "name": "holt",
  "version": "2.0.1",
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "test": "node --max-old-space-size=512 ./node_modules/.bin/jest --selectProjects unit",
    "test:unit": "node --max-old-space-size=512 ./node_modules/.bin/jest --selectProjects unit",
    "test:integration": "bash scripts/run-integration-tests.sh",
    "test:all": "node --max-old-space-size=512 ./node_modules/.bin/jest",
    "test:coverage": "bash scripts/test-coverage.sh",
    "test:coverage:unit": "node --max-old-space-size=1024 ./node_modules/.bin/jest --selectProjects unit --coverage",
    "typecheck:strict": "tsc --noEmit -p tsconfig.strict.json",
    "validate": "npm run lint && npm run typecheck && npm run format:check",
    "sonar:scan": "cd .. && docker run --rm --network=host -e SONAR_HOST_URL=\"${SONAR_HOST_URL:-http://localhost:9000}\" -e SONAR_TOKEN=\"$SONAR_TOKEN\" -e SONAR_SCANNER_OPTS=\"-Xmx3072m\" -e SONAR_SCANNER_JAVASCRIPT_MAX_SPACE=6144 -v \"$(pwd):/usr/src\" sonarsource/sonar-scanner-cli:latest -Dsonar.javascript.node.maxspace=6144",
    "security:semgrep": "cd .. && docker run --rm -v \"$(pwd):/src\" semgrep/semgrep semgrep scan --config p/typescript --config p/react --config p/nextjs --config p/nodejs --config p/owasp-top-ten --config p/secrets --severity ERROR --error /src/app/src /src/scripts",
    "security:deps": "cd .. && docker run --rm -v \"$(pwd):/src\" -w /src ghcr.io/google/osv-scanner:latest --config=osv-scanner.toml --lockfile=app/package-lock.json --format=table",
    "security:scan": "npm run security:semgrep && npm run security:deps",
    "lint:md": "cd .. && npx --yes markdownlint-cli2 \"**/*.md\" \"!**/node_modules/**\"",
    "check:local": "bash scripts/check-local.sh",
    "prepare": "cd .. && git config core.hooksPath .githooks",
    "db:push": "prisma db push && prisma generate",
    "db:generate": "prisma generate",
    "create-admin": "node scripts/create-admin.mjs",
    "seed:cms": "node scripts/seed-cms.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.10",
    "@json2csv/node": "7.0.6",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-slot": "^1.2.5",
    "@rgrove/parse-xml": "^4.2.0",
    "@tanstack/react-query": "^5.101.0",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^8.0.0",
    "axios": "^1.17.0",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "2.1.1",
    "csv-parser": "3.2.1",
    "date-fns": "^4.4.0",
    "formidable": "3.5.4",
    "googleapis": "^171.4.0",
    "handlebars": "4.7.9",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.17.0",
    "mustache": "4.2.0",
    "next": "^16.2.8",
    "next-auth": "^4.24.14",
    "nodemailer": "^8.0.10",
    "papaparse": "5.5.3",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "4.10.38",
    "pg": "^8.21.0",
    "react": "^19.2.7",
    "react-chartjs-2": "5.3.1",
    "react-dom": "^19.2.7",
    "react-toastify": "^11.1.0",
    "sanitize-html": "^2.17.4",
    "stripe": "^22.2.0",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/formidable": "^3.5.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.20",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.8",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-sonarjs": "^4.0.3",
    "jest": "^30.4.2",
    "nyc": "^18.0.0",
    "postcss": "^8.5.10",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.0",
    "ts-jest": "^29.4.11",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.61.0"
  },
  "overrides": {
    "uuid": "^14.0.0",
    "pdfjs-dist": {
      "canvas": "npm:empty-npm-package@1.0.0"
    },
    "glob": {
      "minimatch": "^10.2.5"
    },
    "form-data": "4.0.4",
    "postcss": "^8.5.10",
    "cookie": "0.7.2",
    "follow-redirects": "^1.16.0",
    "semver": "7.6.3",
    "dompurify": "^3.4.1",
    "hono": "^4.12.21",
    "fast-uri": "^3.1.1",
    "@hono/node-server": "^1.19.13",
    "nodemailer": "^8.0.10"
  }
}
