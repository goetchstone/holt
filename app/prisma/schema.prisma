  storeLocationId Int?
  store           StoreLocation? @relation("ShiftStore", fields: [storeLocationId], references: [id])
  clockIn         DateTime       @default(now())
  clockOut        DateTime? // null = still on shift

  @@index([storeLocation, clockIn])
  @@index([staffMemberId, clockIn])
  @@index([storeLocationId])
}

model UpBoardEntry {
  id              Int            @id @default(autoincrement())
  staffMemberId   Int
  staffMember     StaffMember    @relation(fields: [staffMemberId], references: [id])
  storeLocation   String // Board this entry belongs to
  storeLocationId Int?
  store           StoreLocation? @relation("BoardStore", fields: [storeLocationId], references: [id])
  position        Int // Order in rotation (1 = next up)
  status          UpBoardStatus  @default(AVAILABLE)
  statusSince     DateTime       @default(now()) // When status last changed
  customerNote    String? // Optional: who they're helping

  @@unique([storeLocation, position]) // No two people at same position
  @@unique([staffMemberId, storeLocation]) // One entry per person per board
  @@index([storeLocation, status])
}

