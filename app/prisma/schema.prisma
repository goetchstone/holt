  createdBy String?
  updatedBy String?
}

// Designer commission tier rates. Marginal structure: each tier's
// rate applies to the slice of YTD sales that falls within
// [minYtdSales, maxYtdSalesExclusive). When `maxYtdSalesExclusive`
// is NULL the tier is the top bracket. SUPER_ADMIN-editable via the
// commission-tiers report page. Owner-confidential; not shown to
// staff. Origin: owner direction 2026-05-19.
model CommissionTier {
  id                   Int      @id @default(autoincrement())
  label                String   @unique
  minYtdSales          Decimal
  maxYtdSalesExclusive Decimal?
  rate                 Decimal
  sortOrder            Int      @default(0)

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

// ---------------------------------------------------------------------------
// COMMISSION PAYOUTS — one row per salesperson per pay period
// ---------------------------------------------------------------------------
// Records what was actually paid (or queued to be paid) on a specific pay
// cycle, frozen so retroactive changes to SalesOrder data don't rewrite
// history. `tierBreakdown` + `tierDefinitionSnapshot` are JSON so the math
// stays inspectable years later even if CommissionTier rows are edited.
// SUPER_ADMIN-only at the API + UI layer. Origin: owner direction 2026-05-27.

model CommissionPayout {
  id              Int         @id @default(autoincrement())
  staffMemberId   Int
  staffMember     StaffMember @relation(fields: [staffMemberId], references: [id])

  // Custom pay-period range — owner picks each cycle (not necessarily
  // calendar-month aligned). Both ends are inclusive DATEs.
  periodStart     DateTime
  periodEnd       DateTime

  // Sales context, frozen at generation time. `ytdSalesAtStart` is YTD
  // through the day BEFORE periodStart (the "pre-period" baseline);
  // `ytdSalesAtEnd` is YTD through periodEnd (inclusive). The slice
  // (ytdEnd - ytdStart) is what gets commissioned at marginal rates.
  periodSalesAmount Decimal
  ytdSalesAtStart   Decimal
  ytdSalesAtEnd     Decimal

  // Marginal-tier breakdown — array of {tierLabel, rate, sliceAmount,
  // sliceCommission}. One period can span N tiers (e.g. crossing $750k
  // mid-period earns part at 3% + part at 4%).
  tierBreakdown   Json

  // The bottom line.
  commissionAmount Decimal

  // Snapshot of the CommissionTier rows used at generation time. So if
  // the tiers are later edited (e.g. raising the top rate), historical
  // payouts continue to render their original math.
  tierDefinitionSnapshot Json

  // Lock state. lockedAt=null means Draft; non-null means committed.
  // During rollout SUPER_ADMIN can clear lockedAt → null again
  // (recorded as a CommissionPayoutEdit audit row); eventually we'll
  // remove that path.
  lockedAt  DateTime?
  lockedBy  String?

  // Optional payment metadata.
  paidOn DateTime?
  notes  String?

  edits CommissionPayoutEdit[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  // One payout per salesperson per exact period range — a re-run for
  // the same (start, end) updates in place rather than duplicating.
  @@unique([staffMemberId, periodStart, periodEnd])
  @@index([periodEnd])
  @@index([lockedAt])
}

// Field-level audit log for CommissionPayout. Every EDIT to a locked
// payout (whether a number change, a notes update, or an Unlock action)
// writes a row here. SUPER_ADMIN must supply a reason to commit the
// edit; that reason lives in `reason`.

model CommissionPayoutEdit {
  id        Int              @id @default(autoincrement())
  payoutId  Int
  payout    CommissionPayout @relation(fields: [payoutId], references: [id], onDelete: Cascade)

  // The name of the column that changed. "lockedAt" specifically for
  // unlock/lock transitions. JSON for old + new value lets us preserve
  // any field type (number, date, json).
  fieldChanged String
  oldValue     Json
  newValue     Json

  // SUPER_ADMIN-supplied audit comment — required for every edit on a
  // locked payout. Free text.
  reason String

  editedAt DateTime @default(now())
  editedBy String

  @@index([payoutId])
  @@index([editedAt])
}

// Designer sign-off on a bi-weekly pay period. An ACTIVE confirmation
// (reopenedAt IS NULL) freezes that designer's salesperson attribution
// for orders dated inside [periodStart, periodEnd] — the daily import
// and the in-ERP reassignment endpoints all refuse to change it. A
// manager / SUPER_ADMIN can reopen with an audit reason to allow a
// correction; re-confirming clears the reopen fields. See
// docs/domains/commission.md "Pay-period confirmation + attribution
// lock". Origin: owner direction 2026-05-29.
model PayPeriodConfirmation {
  id            Int         @id @default(autoincrement())
  staffMemberId Int
  staffMember   StaffMember @relation("PayPeriodConfirmations", fields: [staffMemberId], references: [id])

  // Inclusive bi-weekly window endpoints (lib/payPeriod.ts).
  periodStart DateTime
  periodEnd   DateTime

  confirmedAt DateTime @default(now())
  confirmedBy String

  // Set when a manager reopens. reopenedAt IS NULL ⇒ the confirmation
  // is ACTIVE (locking). Re-confirm clears these back to null.
  reopenedAt   DateTime?
  reopenedBy   String?
  reopenReason String?

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([staffMemberId, periodStart, periodEnd])
  @@index([periodStart, periodEnd])
}

// A designer flags that their pay-period numbers look wrong instead of
// confirming. This does NOT lock the period (a confirmation does) — it
// raises a flag on the manager review grid so the numbers get fixed
// (rewrite / reassignment) before anyone confirms. Kept separate from
// PayPeriodConfirmation so the attribution-lock logic stays untouched.
// resolvedAt IS NULL ⇒ the issue is OPEN (pending manager review).
model PayPeriodIssue {
  id            Int         @id @default(autoincrement())
  staffMemberId Int
  staffMember   StaffMember @relation("PayPeriodIssues", fields: [staffMemberId], references: [id])

  // Inclusive bi-weekly window endpoints (lib/payPeriod.ts).
  periodStart DateTime
  periodEnd   DateTime

  note       String // what the designer says is wrong
  reportedBy String
  reportedAt DateTime @default(now())

  // Set when a manager resolves the flag. NULL ⇒ still open.
  resolvedAt     DateTime?
  resolvedBy     String?
  resolutionNote String?

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@index([staffMemberId, periodStart, periodEnd])
  @@index([resolvedAt])
}

// ---------------------------------------------------------------------------
