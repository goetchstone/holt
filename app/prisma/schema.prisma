model StaffMember {
  id                    Int            @id @default(autoincrement())
  userId                String?        @unique
  user                  User?          @relation(fields: [userId], references: [id])
  displayName           String // Name shown on up-board
  // Alternate names this person is known by in the POS's `salesperson`
  // field. Reports OR-match on (displayName + every alias) so Sandy can
  // be linked to "Sandra Matheny" without renaming the up-board record.
  // Populated via admin UI or one-off SQL when a mismatch is discovered.
  // Origin: Issue #274, ROADMAP Short-Term #12.
  aliases               String[]       @default([])
  email                 String?        @unique // For matching to User on first login
  // Local-account password (scrypt hash, see lib/auth/password.ts). Null for
  // OAuth-only staff. Only consulted when AUTH_LOCAL_ENABLED turns on the
  // credentials sign-in method.
  passwordHash          String?
  passwordResetTokens   PasswordResetToken[]
  role                  StaffRole      @default(DESIGNER)
  defaultStore          String? // Legacy: the POS store name
  activeStoreLocationId Int?
  activeStoreLocation   StoreLocation? @relation("ActiveStaff", fields: [activeStoreLocationId], references: [id])
  isActive              Boolean        @default(true)
  // Appears on designer-based sales + commission reports. Independent
  // of `role` so a selling MANAGER can be included and an ex-designer
  // excluded. Backfilled true for existing role=DESIGNER staff.
  // Origin: owner direction 2026-05-29.
  isDesigner            Boolean        @default(false)

  shifts               StaffShift[]
  upBoardEntries       UpBoardEntry[]
  payments             Payment[]
  tillsOpened          Till[]                @relation("TillOpener")
  tillsClosed          Till[]                @relation("TillCloser")
  interactions         CustomerInteraction[]
  assignedCases        ServiceCase[]         @relation("CaseAssignee")
  salesPersonCases     ServiceCase[]         @relation("OriginalSalesperson")
  caseNotes            ServiceCaseNote[]
  assignedTasks        ServiceTask[]         @relation("TaskAssignee")
  returnsReceived      Return[]              @relation("ReturnReceivedBy")
  returnsInspected     Return[]              @relation("ReturnInspectedBy")
  designerAppointments ServiceAppointment[]  @relation("DesignerAppointments")
  driverRuns           DeliveryRun[]         @relation("DriverRuns")
  assignedPickLists    PickList[]            @relation("PickListAssignee")
  salesOrders          SalesOrder[]          @relation("OrderSalesPerson")
  splitSales           SalesOrder[]          @relation("SplitSales")
  installer            Installer?
  primaryCustomers     Customer[]            @relation("PrimaryDesigner")
  assignedLeads        Lead[]                @relation("LeadAssignments")
  salesGoals           SalesGoal[]
  proposals            Proposal[]            @relation("ProposalSalesPerson")
  commissionPayouts    CommissionPayout[]
  payPeriodConfirmations PayPeriodConfirmation[] @relation("PayPeriodConfirmations")
  payPeriodIssues        PayPeriodIssue[]        @relation("PayPeriodIssues")
  assignedTickets        Ticket[]                @relation("TicketAssignee")
  authoredTicketMessages TicketMessage[]         @relation("TicketMessageAuthor")
  timeEntries            TimeEntry[]
  availabilityWindows    AvailabilityWindow[]
  calendarBlocks         CalendarBlock[]
  bookings               Booking[]

  // Login activity tracking. Set by the NextAuth jwt callback:
  // lastLoginAt fires on the first-sign-in pass (account + user
  // present); lastSeenAt is bumped on each authenticated request,
  // throttled by a JWT-side timestamp so we don't write per-request.
  // Surfaces "who's been using the system / when last" via /admin/login-activity.
  lastLoginAt DateTime?
  lastSeenAt  DateTime?

  created DateTime  @default(now())
  updated DateTime? @updatedAt
}

// Yearly sales goal per salesperson. The yearlyGoal is distributed across
// months using the monthlyWeights JSON array (12 decimals summing to 1.0).
// When monthlyWeights is null, a standard seasonal pattern is used.
// Bonus is calculated as bonusRate (e.g. 0.06 = 6%) of sales over the
// monthly goal.
model SalesGoal {
  id             Int         @id @default(autoincrement())
  staffMemberId  Int
  staffMember    StaffMember @relation(fields: [staffMemberId], references: [id])
  fiscalYear     Int
  yearlyGoal     Decimal
  bonusRate      Decimal     @default(0.06) // 6% of overage
  monthlyWeights Json? // Optional: array of 12 decimals

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([staffMemberId, fiscalYear])
  @@index([fiscalYear])
}

model StaffShift {
  id              Int            @id @default(autoincrement())
