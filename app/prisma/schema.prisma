// CHART OF ACCOUNTS
// ---------------------------------------------------------------------------

model GLAccount {
  id          Int     @id @default(autoincrement())
  code        String  @unique // e.g., "1000", "4010", "5000"
  name        String // e.g., "Cash", "Sales Revenue", "COGS"
  accountType String // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE
  isActive    Boolean @default(true)

  accountGroupCogs      AccountGroup[]     @relation("CogsMappings")
  accountGroupInventory AccountGroup[]     @relation("InventoryMappings")
  accountGroupSales     AccountGroup[]     @relation("SalesMappings")
  accountGroupReturns   AccountGroup[]     @relation("ReturnsMappings")
  accountGroupTransfers AccountGroup[]     @relation("TransfersMappings")
  accountGroupShrinkage AccountGroup[]     @relation("ShrinkageMappings")
  taxDistricts          TaxDistrict[]
  systemMappings        SystemGLMapping[]  @relation("SystemMappings")
  journalLines          JournalEntryLine[] @relation("JournalLines")

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

model AccountGroup {
  id          Int     @id @default(autoincrement())
  name        String  @unique // e.g., "Furniture", "Services"
  description String?

  cogsAccountId      Int?
  cogsAccount        GLAccount? @relation("CogsMappings", fields: [cogsAccountId], references: [id])
  inventoryAccountId Int?
  inventoryAccount   GLAccount? @relation("InventoryMappings", fields: [inventoryAccountId], references: [id])
  salesAccountId     Int?
  salesAccount       GLAccount? @relation("SalesMappings", fields: [salesAccountId], references: [id])
  returnsAccountId   Int?
  returnsAccount     GLAccount? @relation("ReturnsMappings", fields: [returnsAccountId], references: [id])
  transfersAccountId Int?
  transfersAccount   GLAccount? @relation("TransfersMappings", fields: [transfersAccountId], references: [id])
  shrinkageAccountId Int?
  shrinkageAccount   GLAccount? @relation("ShrinkageMappings", fields: [shrinkageAccountId], references: [id])

  categories Category[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

model SystemGLMapping {
  id          Int        @id @default(autoincrement())
  section     String // POS_PAYMENTS, POS_TRANSACTIONS, AR_TRANSACTIONS, INVENTORY_TRANSACTIONS
  label       String // "Cash", "Visa", "Sales", "Freight", etc.
  glAccountId Int?
  glAccount   GLAccount? @relation("SystemMappings", fields: [glAccountId], references: [id])

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([section, label])
}

// ---------------------------------------------------------------------------
// JOURNAL ENTRIES (QuickBooks export)
// ---------------------------------------------------------------------------

enum JournalType {
  SALES
  PURCHASING
  AR_SALE
  AR_PAYMENT
}

enum JournalStatus {
  DRAFT
  POSTED
  EXPORTED
}

model DailyReconciliationLog {
  id   Int      @id @default(autoincrement())
  date DateTime @db.Date

  // Source-side totals (computed from OrderLineItem + Payment)
  sourceRevenue Decimal @default(0)
  sourceTax     Decimal @default(0)
  sourceCost    Decimal @default(0)
  sourceCash    Decimal @default(0)

  // Journal-side totals (computed from JournalEntryLine)
  journalRevenue Decimal @default(0)
  journalTax     Decimal @default(0)
  journalCost    Decimal @default(0)
  journalCash    Decimal @default(0)

  // Drift = source - journal, per category
  driftRevenue Decimal @default(0)
  driftTax     Decimal @default(0)
  driftCost    Decimal @default(0)
  driftCash    Decimal @default(0)

  balanced       Boolean
  warnings       String[] @default([])
  journalEntryId Int?

  durationMs Int?
  created    DateTime @default(now())
  createdBy  String?

  @@index([date])
  @@index([created])
  @@index([balanced])
}

model JournalEntry {
  id              Int            @id @default(autoincrement())
  journalNumber   String         @unique
  journalDate     DateTime
  journalType     JournalType    @default(SALES)
  status          JournalStatus  @default(DRAFT)
  storeLocation   String?
  storeLocationId Int?
  store           StoreLocation? @relation("JournalStore", fields: [storeLocationId], references: [id])
  totalDebits     Decimal
  totalCredits    Decimal
  notes           String?

  lines JournalEntryLine[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@index([journalDate])
  @@index([status])
}

model JournalEntryLine {
  id             Int          @id @default(autoincrement())
  journalEntryId Int
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  glAccountId    Int
  glAccount      GLAccount    @relation("JournalLines", fields: [glAccountId], references: [id])
  memo           String
  debit          Decimal      @default(0)
  credit         Decimal      @default(0)
  sortOrder      Int          @default(0)

  created DateTime  @default(now())
  updated DateTime? @updatedAt

  @@index([journalEntryId])
}

// ---------------------------------------------------------------------------
// TAX MODEL
// ---------------------------------------------------------------------------

model TaxDistrict {
  id          Int        @id @default(autoincrement())
  shortName   String     @unique // e.g., "CT", "NY-NASSAU"
  state       String // e.g., "CT", "NY"
  authority   String? // governing authority name
  name        String // e.g., "Connecticut State Sales Tax"
  reference   String? // external reference code
  glAccountId Int?
  glAccount   GLAccount? @relation(fields: [glAccountId], references: [id])
  isActive    Boolean    @default(true)

  zipCodes    TaxDistrictZipCode[]
  rules       TaxRule[]
  customers   Customer[]
  salesOrders SalesOrder[]
  lineItems   OrderLineItem[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

model TaxDistrictZipCode {
  id         Int         @id @default(autoincrement())
  districtId Int
  district   TaxDistrict @relation(fields: [districtId], references: [id])
  zipCode    String // 5-digit ZIP
  name       String? // area description

  @@unique([districtId, zipCode])
  @@index([zipCode])
}

model TaxExemptReason {
  id          Int     @id @default(autoincrement())
  name        String  @unique // e.g., "Resale", "Out of State", "Non-Profit"
  description String?

  customers   Customer[]
  salesOrders SalesOrder[]
}

model TaxGroup {
  id             Int     @id @default(autoincrement())
  name           String  @unique // e.g., "Standard Retail", "Services"
  taxBasis       String  @default("NET") // NET or GROSS
  freightTaxable Boolean @default(false)
  miscTaxable    Boolean @default(false)

  rules TaxRule[]

  created DateTime  @default(now())
  updated DateTime? @updatedAt
}

model TaxRule {
  id                      Int         @id @default(autoincrement())
  districtId              Int
  district                TaxDistrict @relation(fields: [districtId], references: [id])
  groupId                 Int
  group                   TaxGroup    @relation(fields: [groupId], references: [id])
  taxRate                 Decimal // e.g., 0.0635 for 6.35%
  triggerPrice            Decimal? // min item price to trigger this rule
  startPrice              Decimal? // start of taxable price range
  stopPrice               Decimal? // cap for taxable price range
  taxIncludedInSalesPrice Boolean     @default(false)
  ruleToAddBeforeCalcId   Int? // self-reference for chained rules
  ruleToAddBeforeCalc     TaxRule?    @relation("TaxRuleChain", fields: [ruleToAddBeforeCalcId], references: [id])
  chainedRules            TaxRule[]   @relation("TaxRuleChain")
  triggerStop             Decimal?
  sortOrder               Int         @default(0)
  isActive                Boolean     @default(true)

  @@unique([districtId, groupId, sortOrder])
}

