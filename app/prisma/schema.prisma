// ---------------------------------------------------------------------------
// BUYER DRAFTS — pre-Product / pre-PurchaseOrder workbench
// ---------------------------------------------------------------------------
//
// The buyer's existing workflow uses an Excel workbook ("Furniture Spring 2026
// OTB.xlsx") with one sheet per vendor. Items live there in a half-finished
// state — fabric/grade/dimensions still being negotiated, part numbers
// proposed, costs penciled in. They don't belong in the live Product catalog
// because they may change before the actual order is placed with the vendor.
//
// `BuyerDraftItem` + `BuyerDraftPurchaseOrder` give that workbook a real home
// in the system. The lifecycle has two terminuses, depending on whether
// the POS is still the system of record:
//
//   Pre-SOR (today):   Draft → Items CSV export → the POS imports the items
//                      and creates products → next Stock-by-Item / Inbound
//                      report flows back through OUR import pipeline →
//                      real `Product` + `PurchaseOrder` created → draft
//                      marked FULFILLED by part-number match.
//
//   Post-SOR (later):  Draft → "Promote to live" → directly creates real
//                      `Product` + `PurchaseOrder` rows → draft FULFILLED.
//                      No export round-trip needed.
//
// Same draft model serves both. Inputs vary: manual entry (furniture),
// HD proposal PDF parser (window treatments), barcode scanning (apparel).
// All three converge on the same draft tables and the same export shape.

enum BuyerDraftItemStatus {
  DRAFT // editable, not yet ready for export
  READY // marked for inclusion in next export batch
  EXPORTED // CSV downloaded; awaiting the POS import
  FULFILLED // matched to a real Product after the POS imported back
  CANCELLED // dropped from the buy
}

enum BuyerDraftPoStatus {
  DRAFT
  READY
  EXPORTED
  FULFILLED
  CANCELLED
}

enum BuyerDraftSource {
  MANUAL // typed by buyer
  HD_PROPOSAL // imported from Hunter Douglas Direct Connect proposal
  APPAREL_SCAN // barcode-scanned apparel item
  CONFIGURATOR // built via vendor style configurator
  HISTORICAL_PO_IMPORT // bulk-imported from an existing real PurchaseOrder (Slice 6.13, 2026-05-22) — used so historical buys can be reconstructed in BuyerDraftBuy form and the Slice 6 performance report can run against them
}

// Description-template selector for `BuyerDraftItem`. Drives which fields
// the wizard exposes and which labels the assembled description string
// uses. Added 2026-05-09 per buyer feedback after seeing the slice 4-lite
// description preview — the buyer's mental model splits cleanly between
// upholstered furniture and case goods (tables / dressers / beds).
enum BuyerDraftItemType {
  UPHOLSTERY // sofa / chair / ottoman — has Fabric / Cushions / Cleaning Code
  CASE_GOODS // table / dresser / bed / cabinet — has Wood Species / Hardware
  OTHER // accessories, rugs, lighting, lamps — generic free-form
}

model BuyerDraftPurchaseOrder {
  id Int @id @default(autoincrement())

  vendorId   Int?
  vendor     Vendor? @relation(fields: [vendorId], references: [id])
  vendorName String // free-text fallback when vendorId is null (new vendors mid-negotiation)

  // Buyer-assigned PO reference (becomes Reference Number in PO export).
  // Empty until the buyer assigns a PON — then unique per vendor.
  referenceNumber String?

  // Stored as DateTime since 2026-05-13 (first-of-month). Was a String
  // column (YYYY-MM / MM-YYYY) — promoted to DateTime so the format-
  // confusion bug class can't recur. Migration
  // `20260513b_expected_ship_month_to_datetime` converted existing
  // canonical-YYYY-MM strings via `TO_TIMESTAMP(value||'-01','YYYY-MM-DD')`.
  // API body coercion (`coerceShipMonthInput` in buyerDraftRequestBody.ts)
  // accepts ISO strings, YYYY-MM, MM-YYYY, Date — all coerce to
  // first-of-month UTC. Display formats to "Month YYYY".
  expectedShipMonth    DateTime?
  expectedDeliveryDate DateTime?

  // Home store the items will land at (drives location code on PO export when
  // the per-line stock location is unset).
  storeLocationId Int?
  storeLocation   StoreLocation? @relation(fields: [storeLocationId], references: [id])

  // Buy parent (added 2026-05-09). Multiple POs roll up into one Buy
  // ("Spring 2026", "Holiday 2025", etc.) so the buyer can plan and track
  // a cohesive multi-vendor purchase against a budget. Optional — POs
  // can also live unassigned.
  buyId Int?
  buy   BuyerDraftBuy? @relation(fields: [buyId], references: [id])

  notes String?

  status        BuyerDraftPoStatus @default(DRAFT)
  exportedAt    DateTime?
  exportBatchId String? // groups PO + its items into the same export download

  items BuyerDraftItem[]

  // Real-PO links (Slice 6.14, 2026-05-22). Many-to-one to
  // `BuyerDraftPoRealPoLink`: one draft PO can be backed by N real
  // PurchaseOrders. Replaces the earlier single-FK shape from Slice 6.13
  // (`importedFromPurchaseOrderId`) — that was 1:1 and couldn't model
  // partial-receive splits where the POS creates a NEW PON for the
  // remainder. The `@unique` constraint moved to `realPoId` on the join
  // table so a given real PO still attaches to at most one buy.
  realPoLinks BuyerDraftPoRealPoLink[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@index([vendorId, status])
  @@index([status])
  @@index([buyId])
}

// Slice 6.14 (2026-05-22) — Many-to-one join from real PurchaseOrder
// to BuyerDraftPurchaseOrder.
//
// Why a join table instead of two FKs:
//   * One real PO attaches to at most ONE draft PO (enforced by
//     `realPoId @unique`). Each real PO belongs to exactly one buy.
//   * One draft PO can be linked to N real POs (no unique constraint
//     on `draftPoId`). Covers:
//       - Forward-flow: draft PO matches a single real PON delivered
//         by the POS's import (Slice 6.14 auto-link, the common case).
//       - Historical-import: operator picks specific real PONs from the
//         catalog and attaches them to a draft PO (Slice 6.13, also 1:1
//         in practice but reuses the same join mechanism).
//       - Partial-receive: original PON + remainder PON both attach to
//         the same draft PO so the buyer sees the full picture (future
//         work — Slice 6.15).
//
// `linkSource` distinguishes how the link was made so audits can tell
// auto-linked vs manually-attached vs historical-bulk-imported.
model BuyerDraftPoRealPoLink {
  id Int @id @default(autoincrement())

  draftPoId Int
  draftPo   BuyerDraftPurchaseOrder @relation(fields: [draftPoId], references: [id], onDelete: Cascade)

  realPoId Int           @unique
  realPo   PurchaseOrder @relation(fields: [realPoId], references: [id], onDelete: Cascade)

  linkSource BuyerDraftPoLinkSource @default(AUTO)

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@index([draftPoId])
}

// How a draft-PO-to-real-PO link was created. Drives audit + future
// "auto-linked - please confirm" UI affordances.
enum BuyerDraftPoLinkSource {
  AUTO // matched + linked by runPurchaseOrdersImport's auto-link sweep (Slice 6.14)
  MANUAL // operator clicked "Link to existing draft PO" or used the API endpoint
  HISTORICAL_IMPORT // bulk-imported from a real PO via the Slice 6.13 modal
}

// Buy parent — groups POs for a buying season / event so the buyer can
// plan and review a cohesive multi-vendor purchase against a budget.
//
// Lifecycle: PLANNING (drafting items + POs) → OPEN (buy is live, may
// still add items) → EXPORTED (CSV's gone to the POS) → CLOSED (Buy is
// historical / archived for record-keeping).
//
// Origin: 2026-05-09 buyer ask: *"perhaps we need a parent table 'buys'
// for this so we can plan and see what we did historically?"*
model BuyerDraftBuy {
  id Int @id @default(autoincrement())

  name   String // "Spring 2026", "Holiday 2025", "Q3 2026 Stocking Refresh"
  season String? // "Spring", "Summer", "Fall", "Winter", "Holiday"
  year   Int? // 2026 — useful for sorting / filtering historical buys

  // Total budget for the buy, in dollars. The UI shows running spend
  // (sum of qty × cost across all items in this buy's POs) against this.
  budget Decimal?

  status   BuyerDraftBuyStatus @default(PLANNING)
  kickoff  DateTime?
  closedAt DateTime?

  notes String?

  pos BuyerDraftPurchaseOrder[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@index([status])
  @@index([year, season])
}

enum BuyerDraftBuyStatus {
  PLANNING // drafting items + POs, nothing exported yet
  OPEN // buy is live — POs may still be added or modified
  EXPORTED // every PO under this buy has been exported to the POS
  CLOSED // archived for historical record
}

model BuyerDraftItem {
  id Int @id @default(autoincrement())

  // ── Vendor / identification ──────────────────────────────────────────
  vendorId   Int?
  vendor     Vendor? @relation(fields: [vendorId], references: [id])
  vendorName String // fallback when vendorId is null

  partNumber  String // proposed part number (vendor's Item#)
  productName String

  // ── Pricing ──────────────────────────────────────────────────────────
  cost   Decimal // unit wholesale cost
  msrp   Decimal? // manufacturer's suggested retail (RRP / "was" price)
  retail Decimal // selling price ("Selling Price / as shown" in the POS)

  // ── Description (configurator-style options string) ──────────────────
  // Concatenated options: "Fabric: Calvin Sky, Grade 16, Cushion: Mayfair,
  // Dimensions: 30W x 39.5D x 34H". Built by the configurator hook for
  // grade-priced vendors; free-text for everything else.
  description String?

  // ── Configurator linkage (optional) ──────────────────────────────────
  vendorStyleId Int?
  vendorStyle   VendorStyle? @relation(fields: [vendorStyleId], references: [id])
  // Captured option selections so the buyer can re-open the configurator
  // and tweak. JSON shape mirrors what the configurator produces.
  configuration Json?

  // ── Configurator-style structured fields ─────────────────────────────
  // Two distinct templates (per buyer feedback 2026-05-09):
  //   UPHOLSTERY: Fabric / Grade / Finish / Cushions / Cleaning Code +
  //               Dimensions + Toss Pillows + Options
  //   CASE_GOODS: Wood Species / Finish / Hardware / Hardware Finish +
  //               Dimensions
  // `itemType` selects the template; `assembleDescription` uses it to
  // emit the right header + field labels. Fields not relevant to the
  // chosen template stay null.
  //
  // We reuse `grade` for Wood Species (case goods) AND Grade
  // (upholstery) since both encode a tier-or-name; the label changes
  // in the UI based on itemType. fabric / cushions / cleaningCode /
  // tossPillows are upholstery-only; hardware / hardwareFinish are
  // case-goods-only.
  itemType       BuyerDraftItemType @default(OTHER)
  grade          String? // upholstery: "13" / "C"; case goods: wood species
  fabric         String? // upholstery
  finish         String? // both
  cushions       String? // upholstery: cushion fill / construction
  cleaningCode   String? // upholstery: "S", "W", "SW", "X"
  tossPillows    String? // upholstery: "(2) 22\" knife edge in Calvin Sky"
  hardware       String? // case goods: pull / knob style
  hardwareFinish String? // case goods: hardware finish color
  options        String? // both: trim / nailhead / build-your-own

  // ── Taxonomy ─────────────────────────────────────────────────────────
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])
  categoryId   Int?
  category     Category?   @relation(fields: [categoryId], references: [id])
  typeId       Int?
  type         Type?       @relation(fields: [typeId], references: [id])

  // ── Dimensions (inches) ──────────────────────────────────────────────
  productWidth  Decimal?
  productLength Decimal? // depth
  productHeight Decimal?

  // ── Stocking program ─────────────────────────────────────────────────
  stockProgram Boolean @default(false) // membership flag
  stockFamily  String? // the POS "Stock Family" label (e.g., "Bevel Arm Stocking")

  // ── Floor plan / vignette ─────────────────────────────────────────────
  // Free-text label so the buyer can group items by display vignette
  // ("Vignette 1", "Living Room", "Front Window"). Multiple items can
  // share a vignette; multiple vignettes can live in the same StockLocation.
  // Drives the "Floor Plan" sheet in the buyer's workbook export.
  vignette String?

  // ── PO grouping ──────────────────────────────────────────────────────
  draftPoId Int?
  draftPo   BuyerDraftPurchaseOrder? @relation(fields: [draftPoId], references: [id])
  qty       Int                      @default(1)

  // ── Where it lands ───────────────────────────────────────────────────
  stockLocationId Int?
  stockLocation   StockLocation? @relation(fields: [stockLocationId], references: [id])

  // ── Apparel-specific ─────────────────────────────────────────────────
  // Vendor-supplied UPC / EAN scanned at receiving. NULL for furniture
  // (the POS auto-creates a barcode); populated for apparel where the
  // vendor's barcode is the canonical identifier.
  barcode String?

  // ── Lifecycle ────────────────────────────────────────────────────────
  status             BuyerDraftItemStatus @default(DRAFT)
  source             BuyerDraftSource     @default(MANUAL)
  exportedAt         DateTime?
  exportBatchId      String?
  fulfilledAt        DateTime?
  // When auto-linked to a real Product after the POS imports the item back.
  fulfilledProductId Int?
  fulfilledProduct   Product?             @relation(fields: [fulfilledProductId], references: [id])

  notes String?

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@index([vendorId, status])
  @@index([draftPoId])
  @@index([partNumber])
  @@index([barcode])
  @@index([fulfilledProductId])
}

