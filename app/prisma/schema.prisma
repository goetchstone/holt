model ServiceCase {
  id               Int                 @id @default(autoincrement())
  caseNumber       String              @unique
  typeId           Int
  type             ServiceCaseType     @relation(fields: [typeId], references: [id])
  statusId         Int
  status           ServiceCaseStatus   @relation(fields: [statusId], references: [id])
  priorityId       Int
  priority         ServiceCasePriority @relation(fields: [priorityId], references: [id])
  summary          String
  customerId       Int?
  customer         Customer?           @relation(fields: [customerId], references: [id])
  salesOrderId     Int?
  salesOrder       SalesOrder?         @relation(fields: [salesOrderId], references: [id])
  // Optional direct link to a PurchaseOrder. Service rows imported
  // from the Customer Service Sheet often have BOTH a sales-order
  // number and a PO number (the upstream PO that
  // sourced the replaced/repaired item). Mirrors ServiceTask's
  // linkedPurchaseOrderId pattern.
  purchaseOrderId  Int?
  purchaseOrder    PurchaseOrder?      @relation("ServiceCasePO", fields: [purchaseOrderId], references: [id])
  vendorId         Int?
  vendor           Vendor?             @relation(fields: [vendorId], references: [id])
  salesPersonId    Int?
  salesPerson      StaffMember?        @relation("OriginalSalesperson", fields: [salesPersonId], references: [id])
  assignedToId     Int?
  assignedTo       StaffMember?        @relation("CaseAssignee", fields: [assignedToId], references: [id])
  storeLocation    String?
  storeLocationId  Int?
  store            StoreLocation?      @relation("CaseStore", fields: [storeLocationId], references: [id])
  preferredContact String?
  itemDescription  String?
  partNo           String?
  resolvedAt       DateTime?
  resolutionNotes  String?

  // Sync provenance for cases imported from an external system (e.g.
  // the Customer Service Sheet xlsx, eventually a Google Form intake).
  // externalSourceId is the idempotency key — re-imports of the same
  // row update the existing case in place rather than creating duplicates.
  // externalSourceLastSeen is bumped on every successful re-sync so
  // operators can spot cases that disappear from the source.
  externalSource         String? // "cs-sheet" | "google-form" | etc.
  externalSourceId       String? @unique
  externalSourceLastSeen DateTime?

  notes  ServiceCaseNote[]
  tasks  ServiceTask[]
  emails ServiceEmail[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@index([statusId])
  @@index([assignedToId])
  @@index([customerId])
  @@index([salesOrderId])
  @@index([purchaseOrderId])
  @@index([externalSource])
}

model ServiceCaseNote {
  id         Int          @id @default(autoincrement())
  caseId     Int
  case       ServiceCase  @relation(fields: [caseId], references: [id], onDelete: Cascade)
  authorId   Int?
  author     StaffMember? @relation(fields: [authorId], references: [id])
  // Snapshot of the original author's display name. Used when we
  // can't resolve authorId to a current StaffMember (former staff,
  // external collaborator on a threaded comment, etc.) so the note
  // still attributes correctly in the UI.
  authorDisplayName String?
  note       String
  isInternal Boolean      @default(true)

  // Per-note idempotency for sheet/form re-imports. For threaded
  // comments this is `cs-sheet-note:{commentGuid}` — the GUID Excel
  // assigns to each threaded comment is globally unique and never
  // reused, so once a comment is imported its note row is immutable
  // (insert-only; never overwritten on subsequent syncs).
  externalSource   String?
  externalSourceId String? @unique

  created   DateTime @default(now())
  createdBy String?

  @@index([caseId, created])
}

model ServiceTask {
  id           Int               @id @default(autoincrement())
  caseId       Int
  case         ServiceCase       @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  status       ServiceTaskStatus @default(PENDING)
  assignedToId Int?
  assignedTo   StaffMember?      @relation("TaskAssignee", fields: [assignedToId], references: [id])
  waitingOn    String?
  dueDate      DateTime?
  completedAt  DateTime?

  linkedOrderId         Int?
  linkedOrder           SalesOrder?    @relation("TaskLinkedOrder", fields: [linkedOrderId], references: [id])
  linkedPurchaseOrderId Int?
  linkedPurchaseOrder   PurchaseOrder? @relation("TaskLinkedPO", fields: [linkedPurchaseOrderId], references: [id])

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@index([caseId])
  @@index([assignedToId])
  @@index([status])
}

model EmailTemplate {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  subject  String
  body     String
  category String
  isActive Boolean @default(true)

  emails ServiceEmail[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

model ServiceEmail {
  id         Int            @id @default(autoincrement())
  caseId     Int
  case       ServiceCase    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  templateId Int?
  template   EmailTemplate? @relation(fields: [templateId], references: [id])
  toAddress  String
  subject    String
  body       String
  sentAt     DateTime       @default(now())
  sentBy     String?
  status     String         @default("SENT")

  @@index([caseId])
}

// ---------------------------------------------------------------------------
// CUSTOMER INTERACTIONS (CRM)
// ---------------------------------------------------------------------------
// Every customer touchpoint: walk-in, phone call, appointment. Created
// automatically when a designer takes a customer from the up-board, or
// manually for phone/email interactions. Can grow into a quote or order.

model CustomerInteraction {
  id              Int                 @id @default(autoincrement())
  staffMemberId   Int
  staffMember     StaffMember         @relation(fields: [staffMemberId], references: [id])
  customerId      Int?
  customer        Customer?           @relation(fields: [customerId], references: [id])
  salesOrderId    Int?
  salesOrder      SalesOrder?         @relation(fields: [salesOrderId], references: [id])
  storeLocation   String
  storeLocationId Int?
  store           StoreLocation?      @relation("InteractionStore", fields: [storeLocationId], references: [id])
