// ---------------------------------------------------------------------------
// TRAFFIC — persisted door-counter rows from Axper
// ---------------------------------------------------------------------------
// One row per 15-minute interval per store per day. Axper exposes
// `entries` / `exits` per interval; we store both (entries == visitors,
// exits == people leaving). Reports roll up via SQL aggregates. A daily
// cron pulls yesterday's data and backfills any gaps in the last 30
// days. Today's data is still pulled live from Axper because the cron
// only runs after midnight ET. Origin: owner direction 2026-05-28.

model TrafficSnapshot {
  id Int @id @default(autoincrement())

  // Full timestamp of the 15-min interval START, expressed in the
  // store's local clock (the organization's configured timezone).
  // Stored as a `DateTime` so reports can `WHERE intervalStart BETWEEN ..`
  // and `GROUP BY DATE_TRUNC('day', intervalStart)` efficiently.
  intervalStart DateTime

  // Raw Axper `store_name` — the source system's own label for the
  // store (e.g. "Downtown", "Main St"). Kept on every row so we can audit
  // back to the source and so rows still upsert correctly if a new
  // Axper store appears before we map it. Mapping to StoreLocation
  // lives in `lib/storeColors.ts:AXPER_TO_STORE_LOCATION`.
  axperStoreName String

  // Optional FK — resolved at import time via the mapping above.
  // Null when a new Axper store appears before its StoreLocation
  // exists. Surfaced on the admin page so the operator can add the
  // mapping + re-run the import.
  storeLocationId Int?
  storeLocation   StoreLocation? @relation(fields: [storeLocationId], references: [id])

  // Per Axper's `entries` field — how many people CAME IN during this
  // interval. The primary signal for conversion math.
  visitors Int

  // Per Axper's `exits` field. Most installations track both; some
  // only track entries. Nullable for resilience.
  exits Int?

  created DateTime @default(now())

  // One row per (interval × store). Lets the import upsert idempotently
  // when re-running for the same day.
  @@unique([intervalStart, axperStoreName])
  @@index([intervalStart])
  @@index([storeLocationId, intervalStart])
}

// ---------------------------------------------------------------------------
// TRAFFIC IMPORT LOG — one row per cron / manual import invocation
// ---------------------------------------------------------------------------
// Used by the admin "Last sync" header on the Axper-traffic import page
// the same way `MailchimpSyncLog` powers the Mailchimp sync admin page.
// Keeps a permanent audit of how many intervals landed each run.

model TrafficSyncLog {
  id            Int       @id @default(autoincrement())
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  kind          String // "axper-traffic-sync" | "axper-traffic-sync:backfill"
  dayFrom       DateTime // first day requested
  dayTo         DateTime // last day requested
  rowsFetched   Int       @default(0)
  rowsInserted  Int       @default(0)
  rowsUpdated   Int       @default(0)
  daysScanned   Int       @default(0)
  daysBackfilled Int      @default(0)
  errors        String[]  @default([])
  triggeredBy   String? // "cron" | actor email | "admin-ui"

  @@index([startedAt])
  @@index([kind, startedAt])
}

// ---------------------------------------------------------------------------
// ORGANIZATION, SETTINGS & INTEGRATION CREDENTIALS
// ---------------------------------------------------------------------------
// Productization foundation. Organization is the tenant boundary: self-hosted
// deployments run a single seeded org (slug "default"); the multi-tenant SaaS
// build issues one row per customer. Tenant-scoped models gain an
// organizationId FK as they are migrated to full isolation.

model Organization {
  id   Int    @id @default(autoincrement())
  name String
  slug String @unique

  settings    AppSettings?
  credentials IntegrationCredential[]

  pages       Page[]
  posts       Post[]
  menus       Menu[]
  mediaAssets MediaAsset[]
  bookings    Booking[]
  tickets     Ticket[]
  timeEntries TimeEntry[]

  services            Service[]
  availabilityWindows AvailabilityWindow[]
  calendarBlocks      CalendarBlock[]
  emailQueue          EmailQueue[]
  blogComments        BlogComment[]
  paymentApplications PaymentApplication[]
  invoices            Invoice[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

// Per-organization branding, locale, and feature configuration (1:1 with
// Organization). `theme` holds brand color tokens (keys mirror the tailwind
// palette) so the UI can be re-skinned from settings without code changes.
// `features` gates premium modules for tiered plans.
model AppSettings {
  id             Int          @id @default(autoincrement())
  organizationId Int          @unique
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  appName      String  @default("Holt")
  companyName  String?
  tagline      String?
  logoUrl      String?
  loginLogoUrl String?
  faviconUrl   String?
  supportEmail String?

  theme Json? // { navy, linen, gold, gray, black, stripe, brandGray, brandBlue }

  currency String @default("USD")
  locale   String @default("en-US")
  timezone String @default("America/New_York")

  features Json? // { "warehousing": true, "dispatch": false, ... }

  bookingConfig Json? // { windowDays, startHour, endHour, slotMinutes }

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

// Encrypted, org-scoped third-party credentials (Mailchimp, Google, Stripe,
// FileMaker, etc.). One row per (org, provider, field). `ciphertext` is an
// AES-256-GCM payload from lib/secretCrypto.ts -- plaintext is NEVER persisted
// or returned to clients. `lastFour` exists only for masked display.
model IntegrationCredential {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  provider   String
  field      String
  ciphertext String
  lastFour   String?

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([organizationId, provider, field])
  @@index([organizationId, provider])
}

// ---------------------------------------------------------------------------
// CMS -- content managed in-app and rendered on the public (site) surface.
// Block content is stored as a typed JSON array; the shared contract and zod
// validation live in lib/cms/blocks.ts (CLAUDE.md rule 7). Null blocks/items
// are treated as an empty array by the parsers, so no DB default is needed.
// ---------------------------------------------------------------------------

enum CmsStatus {
  DRAFT
  PUBLISHED
}

// A managed marketing page. One page per org is flagged isHome and served at
// "/"; the rest resolve by slug. slug is unique within an organization.
model Page {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  slug   String
  title  String
  status CmsStatus @default(DRAFT)
  isHome Boolean   @default(false)

  blocks Json? // ordered ContentBlock[] -- see lib/cms/blocks.ts

  seoTitle       String?
  seoDescription String?

  publishedAt DateTime?

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([organizationId, slug])
  @@index([organizationId, status])
}

// A blog post. Same block model as Page plus dated/listing metadata.
model Post {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  slug    String
  title   String
  excerpt String?
  status  CmsStatus @default(DRAFT)

  blocks Json? // ordered ContentBlock[] -- see lib/cms/blocks.ts

  coverImageUrl String?
  author        String?
  category      String?
  tags          String[] @default([])

  comments BlogComment[]

  seoTitle       String?
  seoDescription String?

  publishedAt DateTime?

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([organizationId, slug])
  @@index([organizationId, status, publishedAt])
}

// A navigation menu (location = "header" | "footer"). items is an ordered
// MenuItem[] ({ label, href, children? }) -- see lib/cms/menu.ts.
model Menu {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  location String
  items    Json? // ordered MenuItem[] -- see lib/cms/menu.ts

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([organizationId, location])
}

// An uploaded media asset (images for blocks, covers, etc.). Files are written
// by the secureUpload pipeline; this row is the catalog entry.
model MediaAsset {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  url      String
  filename String
  mimeType String
  bytes    Int?
  width    Int?
  height   Int?
  alt      String?

  created   DateTime @default(now())
  createdBy String?

  @@index([organizationId])
}

// ---------------------------------------------------------------------------
// Booking -- public, no-login consultation booking. Customers pick a slot on
// the public (site) /book page and we hold it as a Booking row. The .ics
// export + iCal feed (lib/booking/ics.ts) let any standard calendar consume
// these without per-provider OAuth.
// ---------------------------------------------------------------------------

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Booking {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  customerName  String
  customerEmail String
  customerPhone String?
  serviceType   String? // free-text label; preserved for the no-catalog flow

  // Optional links once a Service catalog + staff scheduling are configured.
  serviceId     Int?
  service       Service?     @relation(fields: [serviceId], references: [id])
  staffMemberId Int?
  staffMember   StaffMember? @relation(fields: [staffMemberId], references: [id])

  startsAt DateTime
  endsAt   DateTime

  notes  String?
  status BookingStatus @default(PENDING)

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@index([organizationId, startsAt])
}

// ---------------------------------------------------------------------------
// Helpdesk -- support tickets with a threaded message log. A ticket can be
// raised by a known Customer or by an anonymous public submitter (name +
// email). Each ticket carries a stable publicToken so the submitter can check
// status + reply without logging in. Internal messages (isInternal) are staff-
// only notes and never surface on the public token view.
// ---------------------------------------------------------------------------

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Ticket {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  ticketNumber String @unique
  // Stable random token for the no-login status view (lib/tickets/token.ts).
  publicToken String @unique

  // Origin: a known customer, or an anonymous public submitter.
  customerId     Int?
  customer       Customer? @relation(fields: [customerId], references: [id])
  submitterName  String?
  submitterEmail String?

  subject  String
  status   TicketStatus   @default(OPEN)
  priority TicketPriority @default(MEDIUM)

  assignedToId Int?
  assignedTo   StaffMember? @relation("TicketAssignee", fields: [assignedToId], references: [id])

  resolvedAt DateTime?

  messages    TicketMessage[]
  attachments TicketAttachment[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@index([organizationId, status])
  @@index([assignedToId])
  @@index([customerId])
}

model TicketMessage {
  id       Int    @id @default(autoincrement())
  ticketId Int
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  // Author: a staff member (back-office reply / internal note) or the
  // customer/public submitter (authorName captures the public name).
  authorStaffId Int?
  authorStaff   StaffMember? @relation("TicketMessageAuthor", fields: [authorStaffId], references: [id])
  authorName    String?

  body String
  // Internal notes are staff-only and excluded from the public token view.
  isInternal Boolean @default(false)

  created DateTime @default(now())

  @@index([ticketId, created])
}

// ---------------------------------------------------------------------------
// Time tracking -- staff log billable/non-billable minutes against an optional
// customer. `billedAt` marks an entry as invoiced (a decoupled lifecycle stamp
// rather than a hard FK to the legacy Invoice model -- see
// docs/domains/time-tracking.md). Minutes are stored as an integer; the lib
// parses "1h30m" / "1.5h" / "90" input into minutes.
// ---------------------------------------------------------------------------

model TimeEntry {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  staffMemberId Int
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id])

  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])

  description String
  minutes     Int
  date        DateTime @db.Date
  isBillable  Boolean  @default(true)
  billedAt    DateTime?

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@index([organizationId, date])
  @@index([staffMemberId, date])
  @@index([customerId])
}

// ---------------------------------------------------------------------------
// Scheduling -- a bookable Service catalog with weekly AvailabilityWindows and
// one-off CalendarBlocks (time off / closures). Drives the public /book slot
// picker: slots = the matching windows, stepped by the service duration, minus
// existing bookings and blocks. When no Service + windows are configured the
// booking flow falls back to the flat AppSettings.bookingConfig business hours,
// so existing deployments keep working with zero config.
// ---------------------------------------------------------------------------

model Service {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  name            String
  slug            String
  description     String?
  durationMinutes Int          @default(30)
  bufferMinutes   Int          @default(0)
  price           Decimal?     @db.Decimal(10, 2)
  isPublic        Boolean      @default(true)
  isActive        Boolean      @default(true)
  sortOrder       Int          @default(0)

  windows  AvailabilityWindow[]
  bookings Booking[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([organizationId, slug])
  @@index([organizationId, isActive])
}

model AvailabilityWindow {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // serviceId null = applies to every service; staffMemberId null = whole
  // business (org-wide hours). MVP UI manages org-wide windows; the columns
  // support per-service / per-staff refinement later.
  serviceId     Int?
  service       Service?     @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staffMemberId Int?
  staffMember   StaffMember? @relation(fields: [staffMemberId], references: [id])

  dayOfWeek Int // 0 = Sunday .. 6 = Saturday
  startTime String // "HH:MM" 24h, local to the org timezone
  endTime   String // "HH:MM"

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@index([organizationId, dayOfWeek])
  @@index([serviceId])
}

model CalendarBlock {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // staffMemberId null = a business-wide closure (blocks all bookings).
  staffMemberId Int?
  staffMember   StaffMember? @relation(fields: [staffMemberId], references: [id])

  startsAt DateTime
  endsAt   DateTime
  reason   String?

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@index([organizationId, startsAt])
}

// ---------------------------------------------------------------------------
// Email queue -- durable transactional email (booking confirmations, ticket
// updates). A handler enqueues a row with the rendered subject + html; the
// sender (lib/email/queue.ts) delivers it via nodemailer using SMTP creds from
// the IntegrationCredential store or env. Sending no-ops when SMTP is
// unconfigured, so a fresh deployment runs fine with email off.
// ---------------------------------------------------------------------------

enum EmailStatus {
  PENDING
  SENT
  FAILED
}

model EmailQueue {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  toAddress   String
  subject     String
  html        String
  templateKey String? // categorization, e.g. "booking-confirmation"

  status      EmailStatus @default(PENDING)
  attempts    Int         @default(0)
  lastError   String?
  scheduledAt DateTime    @default(now())
  sentAt      DateTime?

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?

  @@index([organizationId, status])
  @@index([status, scheduledAt])
}

// ---------------------------------------------------------------------------
// Blog comments -- public, moderated. A visitor submits a comment on a Post; it
// lands PENDING and only renders on the public site once a staffer APPROVES it.
// IP + user-agent are captured for spam triage. Gated by the `blogComments`
// feature flag (off by default).
// ---------------------------------------------------------------------------

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
  SPAM
}

model BlogComment {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  postId Int
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  authorName  String
  authorEmail String
  content     String

  status    CommentStatus @default(PENDING)
  ipAddress String?
  userAgent String?

  approvedAt DateTime?
  approvedBy String?

  created DateTime  @default(now())
  updated DateTime? @updatedAt

  @@index([postId, status])
  @@index([organizationId, status])
}

// ---------------------------------------------------------------------------
// Legacy Archive (feature flag `legacyArchive`, 2026-06-10) — read-only
// snapshot of a client's PREVIOUS system's sales history, loaded once at
// onboarding so staff can answer "what did this customer buy before the
// cutover?" Deliberately isolated: no FK to live tables, never written by
// imports, never included in reports. Contact fields are per-order snapshots
// (no dependency on the live Customer table). The column-mapping that fills
// these tables lives in a per-deployment import config, not in code — see
// scripts/import-legacy-archive.mjs and docs/domains/legacy-archive.md.

model LegacyOrder {
  id               Int       @id @default(autoincrement())
  orderNumber      String    @unique // idempotency key from the source system
  salesOrderNumber String?
  saleDate         DateTime?
  customerCode     String?
  customerName     String?
  companyName      String?
  email            String?
  phone            String?
  phone2           String?
  address          String?
  city             String?
  state            String?
  zip              String?
  grandTotal       Decimal?
  taxTotal         Decimal?

  lines LegacyOrderLine[]

  created DateTime @default(now())

  @@index([saleDate])
  @@index([customerCode])
}

model LegacyOrderLine {
  id            Int         @id @default(autoincrement())
  legacyOrderId Int
  legacyOrder   LegacyOrder @relation(fields: [legacyOrderId], references: [id], onDelete: Cascade)
  lineNumber    Int?
  sku           String?
  description   String?
  lineTotal     Decimal?
  vendor        String?
  vendorSku     String?
  manufacturer  String?
  // Free-form passthrough columns for source fields with no generic home.
  misc1         String?
  misc2         String?
  misc3         String?
  misc4         String?
  misc5         String?

  @@index([legacyOrderId])
}

model LegacyImportLog {
  id          Int       @id @default(autoincrement())
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  sourceFile  String?
  ordersLoaded Int      @default(0)
  linesLoaded  Int      @default(0)
  errors      String[]
  triggeredBy String?

  @@index([startedAt])
}

// Single-use password-reset tokens for local-account staff (feature: the
// credentials sign-in method, AUTH_LOCAL_ENABLED). Only a SHA-256 hash of the
// raw token is stored — a DB leak cannot be replayed as reset links. Tokens
// expire after an hour and are consumed exactly once; requesting a new one
// voids any still-open ones for the same staff member.
model PasswordResetToken {
  id            Int         @id @default(autoincrement())
  staffMemberId Int
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  tokenHash     String      @unique
  expiresAt     DateTime
  usedAt        DateTime?

  created DateTime @default(now())

  @@index([staffMemberId])
}

// Helpdesk ticket file attachments (screenshots, PDFs). Uploaded by staff
// from the ticket detail or by the customer from the public status page
// (token-authed). Files live under data/uploads/attachments with random
// names and are served by /api/uploads/[...path]; deleting the ticket
// cascades the rows (files are cleaned by ops, not in-request).
model TicketAttachment {
  id       Int    @id @default(autoincrement())
  ticketId Int
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  filename String
  url      String
  mimeType String
  bytes    Int?
  // Staff display name or the public submitter name — display only.
  uploadedBy String?

  created DateTime @default(now())

  @@index([ticketId])
}
