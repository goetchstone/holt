// app/prisma/schema.prisma
//
// Holt -- Retail Business Management Platform
// Database schema for product catalog, pricing engine, inventory,
// purchasing, sales, and integrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// CORE CATALOG & PRODUCT STRUCTURE
// ---------------------------------------------------------------------------

model Vendor {
  id              Int                @id @default(autoincrement())
  name            String             @unique
  code            String?            @unique // Short vendor code (e.g., "WH", "AL", "HK")
  pricingModel    VendorPricingModel @default(FLAT)
  defaultMarkup   Decimal? // Default retail markup multiplier (e.g., 2.5)
  defaultDiscount Decimal? // Dealer discount off retail (e.g., 0.40 for 40% off)
  costMultiplier  Decimal?           @map("cost_multiplier") // Cost = retail * multiplier (e.g., 0.44)
  mapEnforced     Boolean            @default(false)
  website         String?
  accountNumber   String?
  paymentTerms    String? // e.g., "Net 30"
  freightTerms    String? // e.g., "FOB Factory"
  minimumOrder    Decimal?
  address         String?
  city            String?
  state           String?
  zip             String?
  phone           String?
  email           String?
  notes           String?

  contacts        VendorContact[]
  products        Product[]
  vendorStyles    VendorStyle[]
  priceDimensions VendorPriceDimension[]
  optionGroups    VendorOptionGroup[]
  programs        VendorProgram[]
  purchaseOrders  PurchaseOrder[]
  priceLists      PriceList[]
  fabrics         FabricCatalog[]
  seComponents    SEComponent[]
  serviceCases    ServiceCase[]

  allowTradeDiscount Boolean @default(true)

  consignmentItems         ConsignmentItem[]
  consignmentReceipts      ConsignmentReceipt[]
  consignmentPayments      ConsignmentPaymentBatch[]
  consignmentVendorReturns ConsignmentVendorReturn[]

  buyerDraftItems          BuyerDraftItem[]
  buyerDraftPurchaseOrders BuyerDraftPurchaseOrder[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

// Categorizes how a vendor prices their products so the pricing engine
// knows which calculation path to follow.
enum VendorPricingModel {
  FLAT // Hooker, Currey, INET, Jellycat, Matouk, SMEG, etc.
  GRADE_BASED // Wesley Hall, HF Custom, Lee, MT Company, CR Laine
  FRAME_PLUS_CUSHION // Jensen, Kingsley Bate, American Leather
  SPECIES_MATRIX // Simply Amish
  MULTI_AXIS // Zimmerman Chair (species x finish x upholstery)
  AREA_BASED // Fibreworks (per sq ft / sq yd)
  SIZE_BASED // Downright, Pom Pom, Redford House
}

model VendorContact {
  id        Int     @id @default(autoincrement())
  vendorId  Int
  name      String
  email     String?
  phone     String?
  role      String?
  isPrimary Boolean @default(false)
  vendor    Vendor  @relation(fields: [vendorId], references: [id])

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

// ---------------------------------------------------------------------------
// VENDOR STYLE — Configurable catalog templates
//
// Represents a vendor's catalog entry for a configurable item. A VendorStyle
// is NOT a physical product — it's a template from the vendor's price list.
// It becomes a Product when configured and ordered (e.g., "Wesley Hall 1060"
// is a style; "WH-1060-G20" is the product materialized from that style in
// Grade 20).
//
// Flat-priced vendors (Hooker, etc.) use Product directly — no VendorStyle.
//
// The import pipeline creates VendorStyles from vendor price lists. For 2D
// vendors (style × grade), the import can optionally auto-materialize
// Products for each style+grade combination. Existing Products (e.g., from
// the POS) can be linked to VendorStyles via vendorStyleId for automatic
// pricing updates when a new price list is imported.
// ---------------------------------------------------------------------------

model VendorStyle {
  id           Int         @id @default(autoincrement())
  styleNumber  String // Vendor's style/item number (e.g., "1060", "82020", "CS-AUSTIN")
  name         String
  description  String?
  vendorId     Int
  vendor       Vendor      @relation(fields: [vendorId], references: [id])
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])
  categoryId   Int?
  category     Category?   @relation(fields: [categoryId], references: [id])
  typeId       Int?
  type         Type?       @relation(fields: [typeId], references: [id])
  collectionId Int?
  collection   Collection? @relation(fields: [collectionId], references: [id])

  // Base pricing (COM/starting price — lowest tier or starting cost)
  baseCost   Decimal?
  baseRetail Decimal?
  mapPrice   Decimal?

  // Grade-based: how many yards/sq ft of material are needed
  comYardage        Decimal? // Plain yardage (54" plain fabric)
  comYardagePattern Decimal? // Pattern yardage (larger repeat fabrics)
  comYardageRepeat  Decimal? // Repeat yardage (railroaded/directional fabrics)
  gradeRiser        Decimal? // Dollar amount per grade step beyond published grades

  // Standard construction details (parsed from price list)
  standardSeat    String? // e.g., "Spring Down", "Comfort Down BDB"
  standardBack    String? // e.g., "Spring Down", "Tight Back"
  standardPillows String? // e.g., "(2) 22\" Throw Pillows"
  finish          String? // Standard finish (e.g., "Recessed Espresso Leg", "Specify")

  // Frame+Cushion: the frame component price
  framePrice Decimal?
  cushionRef String? // Reference to cushion model (e.g., "CUS89")

  // Area-based: price per unit of area
  pricePerSqFt Decimal?
  pricePerSqYd Decimal?

  // Physical attributes (base dimensions — may vary by configuration)
  length     Float?
  width      Float?
  depth      Float?
  height     Float?
  seatHeight Float?
  armHeight  Float?
  seatDepth  Float?
  weight     Float?

  // Product image (line drawing extracted from price list PDF)
  imageUrl String?

  // Status
  isActive       Boolean @default(true)
  isDiscontinued Boolean @default(false)

  // Pricing relations
  gradePrices     StyleGradePrice[]
  speciesPrices   StyleSpeciesPrice[]
  axisPrices      StyleAxisPrice[]
  optionOverrides StyleOptionOverride[]

  // Products materialized from this style
  configuredProducts Product[]

  // Order references (trace back from order to the template)
  orderLineItems     OrderLineItem[]
  purchaseOrderItems PurchaseOrderItem[]
  proposalLineItems  ProposalLineItem[]  @relation("ProposalVendorStyle")
  buyerDraftItems    BuyerDraftItem[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([styleNumber, vendorId])
  @@index([vendorId, isActive])
}

// ---------------------------------------------------------------------------
// PRODUCT — Physical items in inventory
//
// Products come from the POS imports (flat items) or are created when
// a VendorStyle is configured and ordered. Products are NOT unique by
// (productNumber, vendorId) — the same part number from the same vendor
// can appear multiple times. the POS records deduplicate by externalId.
// ---------------------------------------------------------------------------

model Product {
  id            Int         @id @default(autoincrement())
  externalId    Int?        @unique
  productNumber String
  name          String
  description   String?
  vendorId      Int
  vendor        Vendor      @relation(fields: [vendorId], references: [id])
  departmentId  Int
  department    Department  @relation(fields: [departmentId], references: [id])
  categoryId    Int
  category      Category    @relation(fields: [categoryId], references: [id])
  typeId        Int?
  type          Type?       @relation(fields: [typeId], references: [id])
  collectionId  Int?
  collection    Collection? @relation(fields: [collectionId], references: [id])

  // Provenance: which VendorStyle was this configured from? (null = flat-priced stock)
  vendorStyleId Int?
  vendorStyle   VendorStyle? @relation(fields: [vendorStyleId], references: [id])

  // Configuration snapshot (JSON of selected grade/species/size/options at creation time)
  configSnapshot String?

  // Base pricing for flat-priced products (also serves as COM/starting price for grade-based)
  baseCost   Decimal?
  baseRetail Decimal?
  mapPrice   Decimal?

  // Physical attributes
  length     Float?
  width      Float?
  depth      Float?
  height     Float?
  seatHeight Float?
  armHeight  Float?
  seatDepth  Float?
  weight     Float?
  cubicFeet  Float?

  // Product image (line drawing extracted from price list PDF)
  imageUrl String?

  // Shipping
  freightClass String?
  shipsVia     String?
  cartonQty    Int?

  // Status
  isActive       Boolean @default(true)
  isDiscontinued Boolean @default(false)
  season         String?

  // Grade-based products: how many yards/sq ft of material are needed
  comYardage        Decimal? // Plain yardage (54" plain fabric)
  comYardagePattern Decimal? // Pattern yardage (larger repeat fabrics)
  comYardageRepeat  Decimal? // Repeat yardage (railroaded/directional fabrics)
  gradeRiser        Decimal? // Dollar amount per grade step beyond published grades

  // Standard construction details (parsed from price list)
  standardSeat    String? // e.g., "Spring Down", "Comfort Down BDB"
  standardBack    String? // e.g., "Spring Down", "Tight Back"
  standardPillows String? // e.g., "(2) 22\" Throw Pillows"

  // Frame+Cushion products: the frame component price
  framePrice Decimal?
  cushionRef String? // Reference to cushion model (e.g., "CUS89")

  // Area-based products: price per unit of area
  pricePerSqFt Decimal?
  pricePerSqYd Decimal?

  upcs            Upc[]
  variants        ProductVariant[]
  gradePrices     ProductGradePrice[]
  speciesPrices   ProductSpeciesPrice[]
  axisPrices      ProductAxisPrice[]
  optionOverrides ProductOptionOverride[]

  reconciliations             Reconciliation[]
  inventoryCounts             PhysicalInventoryCount[]
  orderLineItems              OrderLineItem[]
  purchaseOrderItems          PurchaseOrderItem[]
  inventoryTransfers          InventoryTransfer[]
  inventoryPositions          InventoryPosition[]
  reconciledUnidentifiedScans UnidentifiedScan[]
  returns                     Return[]

  serviceType          ServiceAppointmentType?
  consignmentItems     ConsignmentItem[]
  pickListItems        PickListItem[]
  inventoryFreezeItems InventoryFreezeItem[]
  proposalLineItems    ProposalLineItem[]

  fulfilledBuyerDrafts BuyerDraftItem[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

// Vendor collections group styles/products (e.g., "CORAL" for Jensen, "Curata" for Hooker)
model Collection {
  id           Int           @id @default(autoincrement())
  vendorId     Int
  name         String
  products     Product[]
  vendorStyles VendorStyle[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([vendorId, name])
}

// For flat-priced vendors where each size/color/finish is a distinct purchasable SKU
model ProductVariant {
  id        Int     @id @default(autoincrement())
  productId Int
  sku       String?
  upc       String?
  size      String?
  color     String?
  finish    String?
  material  String?

  cost      Decimal?
  wholesale Decimal?
  retail    Decimal?
  mapPrice  Decimal?

  width  Decimal?
  length Decimal?
  height Decimal?
  weight Decimal?

  isActive Boolean @default(true)

  product            Product             @relation(fields: [productId], references: [id])
  purchaseOrderItems PurchaseOrderItem[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

// ---------------------------------------------------------------------------
// PRICING ENGINE -- Flexible multi-dimensional pricing
// ---------------------------------------------------------------------------

// Tracks price list versions so we can keep history when vendors update prices
model PriceList {
  id            Int       @id @default(autoincrement())
  vendorId      Int
  vendor        Vendor    @relation(fields: [vendorId], references: [id])
  name          String // e.g., "October 2025 Wholesale"
  effectiveDate DateTime
  expiresDate   DateTime?
  priceType     PriceType
  isActive      Boolean   @default(true)
  sourceFile    String? // Original file name for reference
  notes         String?

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([vendorId, name])
  @@index([vendorId, isActive])
}

enum PriceType {
  COST // Dealer cost / wholesale
  WHOLESALE // Wholesale
  RETAIL // Suggested retail
  MSRP // Manufacturer suggested retail
  MAP // Minimum advertised price
  STOCKING // Stocking dealer price
}

// ---------------------------------------------------------------------------
// GRADE-BASED PRICING (Wesley Hall, HF Custom, Lee, MT Company, CR Laine, etc.)
//
// Each vendor defines their own set of price dimensions (grades). A dimension
// is a named pricing axis like "Fabric Grade" or "Leather Grade". Each
// dimension has tiers (the individual grade levels like "14", "15", ..., "35").
// ---------------------------------------------------------------------------

// A pricing axis defined by a vendor (e.g., "Fabric Grade", "Leather Grade",
// "Wood Species", "Finish Category", "Cushion Grade")
model VendorPriceDimension {
  id            Int           @id @default(autoincrement())
  vendorId      Int
  vendor        Vendor        @relation(fields: [vendorId], references: [id])
  name          String // e.g., "Fabric Grade", "Wood Species", "Finish Tier"
  dimensionType DimensionType

  tiers PriceDimensionTier[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([vendorId, name])
}

enum DimensionType {
  FABRIC_GRADE // Fabric grade levels (14, 15, ..., 35 or A, B, C)
  LEATHER_GRADE // Leather grade levels (C, D, F, G, H, J)
  WOOD_SPECIES // Oak, Maple, Cherry, Walnut, etc.
  FINISH_TIER // Renew/Heritage, Renaissance, Weathered
  CUSHION_GRADE // Frame+cushion grade (A, B, C, D or C, D, E, U)
  SIZE // Twin, Full, Queen, King, etc.
  MATERIAL_TIER // COM, Fabric, Faux Leather
  CUSTOM // Vendor-specific dimension that does not fit other types
}

// An individual tier within a pricing dimension
// e.g., For "Fabric Grade" dimension: "COM", "14", "15", ..., "35"
// e.g., For "Wood Species" dimension: "Oak", "Maple", "Cherry", "Walnut"
model PriceDimensionTier {
  id          Int                  @id @default(autoincrement())
  dimensionId Int
  dimension   VendorPriceDimension @relation(fields: [dimensionId], references: [id])
  name        String // Display name: "Grade 14", "Oak", "COM"
  code        String // Short code: "14", "OAK", "COM"
  sortOrder   Int                  @default(0)

  // For fabric/leather grades: price per yard or per sq ft at this tier level
  unitPrice Decimal? // e.g., Grade 14 fabric = $22/yard

  // Product pricing relations (for materialized products)
  gradePrices   ProductGradePrice[]
  speciesPrices ProductSpeciesPrice[]
  axisPrices    ProductAxisPrice[]

  // Style pricing relations (for catalog templates)
  styleGradePrices   StyleGradePrice[]
  styleSpeciesPrices StyleSpeciesPrice[]
  styleAxisPrices    StyleAxisPrice[]

  fabrics FabricCatalog[]

  created DateTime  @default(now())
  updated DateTime? @updatedAt

  @@unique([dimensionId, code])
}

// ---------------------------------------------------------------------------
// FABRIC & MATERIAL CATALOG
//
// Maps individual fabric names/codes to a vendor's grade tier. This lets the
// configurator answer "I want Crypton Tweed in color Indigo" → Grade 20 →
// the price for the selected product in Grade 20.
// ---------------------------------------------------------------------------

model FabricCatalog {
  id       Int                @id @default(autoincrement())
  vendorId Int
  vendor   Vendor             @relation(fields: [vendorId], references: [id])
  tierId   Int
  tier     PriceDimensionTier @relation(fields: [tierId], references: [id])

  fabricName    String // Collection/pattern name: "Crypton Tweed", "Artisan Weave"
  fabricCode    String? // Vendor's fabric SKU/code: "0858-53", "AW-IND"
  colorName     String  @default("") // Color / colorway: "Indigo", "Pewter", "Natural"
  colorCode     String? // Vendor's color code: "53", "IND"
  patternRepeat String? // Pattern repeat info: "13.5\"H x 14\"V"
  width         String? // Fabric width: "54\"", "118\""
  content       String? // Fiber content: "100% Polyester", "72% Poly / 28% Cotton"
  collection    String? // Marketing collection: "Performance", "Luxe", "Essentials"
  usage         String? // Intended usage: "Upholstery", "Drapery", "Multi-Purpose"

  isActive       Boolean @default(true)
  isDiscontinued Boolean @default(false)
  notes          String?
  imageUrl       String? // Swatch image URL (future use)

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([vendorId, fabricName, colorName])
  @@index([vendorId, tierId])
  @@index([vendorId, fabricName])
  @@index([vendorId, isActive])
}

// ---------------------------------------------------------------------------
// PRODUCT PRICING — Links Product to dimension tiers with costs
//
// These are for materialized products (flat-priced or configured items that
// have been ordered). When a Product is created from a VendorStyle, these
// pricing rows can be copied from the Style* equivalents.
// ---------------------------------------------------------------------------

// The core grade-based pricing row: what does product X cost at grade Y?
// Used for: Wesley Hall, HF Custom, Lee, MT Company, CR Laine, Foundations
// One row per product per grade tier.
model ProductGradePrice {
  id        Int                @id @default(autoincrement())
  productId Int
  product   Product            @relation(fields: [productId], references: [id])
  tierId    Int
  tier      PriceDimensionTier @relation(fields: [tierId], references: [id])

  cost      Decimal? // Dealer cost at this grade
  wholesale Decimal? // Wholesale at this grade
  retail    Decimal? // Retail at this grade
  msrp      Decimal? // MSRP at this grade

  created DateTime  @default(now())
  updated DateTime? @updatedAt

  @@unique([productId, tierId])
  @@index([productId])
}

// Wood species-based pricing: what does product X cost in species Y?
// Used for: Simply Amish (separate from grade because products can have
// both a species price AND an upholstery grade on top)
model ProductSpeciesPrice {
  id        Int                @id @default(autoincrement())
  productId Int
  product   Product            @relation(fields: [productId], references: [id])
  tierId    Int
  tier      PriceDimensionTier @relation(fields: [tierId], references: [id])

  cost      Decimal?
  wholesale Decimal?
  retail    Decimal?

  created DateTime  @default(now())
  updated DateTime? @updatedAt

  @@unique([productId, tierId])
  @@index([productId])
}

// Multi-axis pricing: product X at the intersection of dimension tiers Y + Z + ...
// Used for: Zimmerman Chair (species x finish x upholstery level)
// Stores up to 3 tier references per price point.
model ProductAxisPrice {
  id        Int     @id @default(autoincrement())
  productId Int
  product   Product @relation(fields: [productId], references: [id])

  tier1Id Int
  tier1   PriceDimensionTier @relation(fields: [tier1Id], references: [id])
  tier2Id Int?
  tier3Id Int?

  cost      Decimal?
  wholesale Decimal?
  retail    Decimal?

  created DateTime  @default(now())
  updated DateTime? @updatedAt

  @@unique([productId, tier1Id, tier2Id, tier3Id])
  @@index([productId])
}

// ---------------------------------------------------------------------------
// STYLE PRICING — Links VendorStyle to dimension tiers with costs
//
// These are the catalog/template prices from vendor price lists. The import
// pipeline populates these. When a Product is materialized from a VendorStyle,
// the relevant pricing data is copied to the Product* equivalents above.
// ---------------------------------------------------------------------------

// Grade-based pricing: what does style X cost at grade Y?
// Used for: Wesley Hall, HF Custom, Lee, MT Company, CR Laine, Foundations
// One row per style per grade tier.
model StyleGradePrice {
  id            Int                @id @default(autoincrement())
  vendorStyleId Int
  vendorStyle   VendorStyle        @relation(fields: [vendorStyleId], references: [id], onDelete: Cascade)
  tierId        Int
  tier          PriceDimensionTier @relation(fields: [tierId], references: [id])

  cost      Decimal? // Dealer cost at this grade
  wholesale Decimal? // Wholesale at this grade
  retail    Decimal? // Retail at this grade
  msrp      Decimal? // MSRP at this grade

  created DateTime  @default(now())
  updated DateTime? @updatedAt

  @@unique([vendorStyleId, tierId])
  @@index([vendorStyleId])
}

// Wood species-based pricing: what does style X cost in species Y?
// Used for: Simply Amish, Gat Creek line items
model StyleSpeciesPrice {
  id            Int                @id @default(autoincrement())
  vendorStyleId Int
  vendorStyle   VendorStyle        @relation(fields: [vendorStyleId], references: [id], onDelete: Cascade)
  tierId        Int
  tier          PriceDimensionTier @relation(fields: [tierId], references: [id])

  cost      Decimal?
  wholesale Decimal?
  retail    Decimal?

  created DateTime  @default(now())
  updated DateTime? @updatedAt

  @@unique([vendorStyleId, tierId])
  @@index([vendorStyleId])
}

// Multi-axis pricing: style X at the intersection of dimension tiers Y + Z + ...
// Used for: Gat Creek Custom Shop (species x width x length), Zimmerman Chair
// Stores up to 3 tier references per price point.
model StyleAxisPrice {
  id            Int         @id @default(autoincrement())
  vendorStyleId Int
  vendorStyle   VendorStyle @relation(fields: [vendorStyleId], references: [id], onDelete: Cascade)

  tier1Id Int
  tier1   PriceDimensionTier @relation(fields: [tier1Id], references: [id])
  tier2Id Int?
  tier3Id Int?

  cost      Decimal?
  wholesale Decimal?
  retail    Decimal?

  created DateTime  @default(now())
  updated DateTime? @updatedAt

  @@unique([vendorStyleId, tier1Id, tier2Id, tier3Id])
  @@index([vendorStyleId])
}

// ---------------------------------------------------------------------------
// OPTIONS & SURCHARGES
//
// Handles all the add-on pricing: cushion upgrades, finishes, trim, welt,
// arm caps, spring-down, power recline, skirts, borders, monogramming, etc.
// ---------------------------------------------------------------------------

// A category of options a vendor offers (e.g., "Cushion Type", "Nail Trim",
// "Decorative Finish", "Rug Border")
model VendorOptionGroup {
  id          Int     @id @default(autoincrement())
  vendorId    Int
  vendor      Vendor  @relation(fields: [vendorId], references: [id])
  name        String // e.g., "Cushion Upgrade", "Trim", "Finish"
  description String?

  options VendorOption[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([vendorId, name])
}

// A specific option within a group (e.g., "Spring-Down Luxe" within "Cushion Upgrade")
model VendorOption {
  id                Int               @id @default(autoincrement())
  groupId           Int
  group             VendorOptionGroup @relation(fields: [groupId], references: [id])
  name              String // e.g., "SM-Spring Down Luxe"
  code              String? // Short code for order entry
  surchargeType     SurchargeType     @default(FLAT)
  defaultSurcharge  Decimal           @default(0) // Default surcharge if not overridden per product/style
  sortOrder         Int               @default(0)
  requiresTextInput Boolean           @default(false) // Show text input when selected (trim details, etc.)
  textInputLabel    String? // Placeholder/label for the text input

  overrides      ProductOptionOverride[]
  styleOverrides StyleOptionOverride[]

  created DateTime  @default(now())
  updated DateTime? @updatedAt

  @@unique([groupId, name])
}

enum SurchargeType {
  FLAT // Fixed dollar amount (e.g., $66 for contrast welt)
  PERCENTAGE // Percentage of base price (e.g., 10% for wire brush finish)
  PER_UNIT // Per yard, per sq ft, etc. (e.g., $11.50/sq ft for custom rug)
}

// Per-product override of option pricing. When a product has a different surcharge
// than the vendor default, or when an option is N/A for a specific product.
// e.g., Wesley Hall style 1060 charges $165 for Spring-Down Luxe, but style 1034
// does not offer it at all.
model ProductOptionOverride {
  id        Int          @id @default(autoincrement())
  productId Int
  product   Product      @relation(fields: [productId], references: [id])
  optionId  Int
  option    VendorOption @relation(fields: [optionId], references: [id])

  surcharge   Decimal? // Override surcharge amount (null = use default)
  isAvailable Boolean  @default(true) // false = this option is N/A for this product
  isStandard  Boolean  @default(false) // true = included at no extra charge
  notes       String? // e.g., "Small nails only, around top & on base"

  created DateTime  @default(now())
  updated DateTime? @updatedAt

  @@unique([productId, optionId])
  @@index([productId])
}

// Per-style override of option pricing. Same structure as ProductOptionOverride
// but references VendorStyle instead of Product. Used by the configurator to
// show available options and surcharges for a catalog template.
model StyleOptionOverride {
  id            Int          @id @default(autoincrement())
  vendorStyleId Int
  vendorStyle   VendorStyle  @relation(fields: [vendorStyleId], references: [id], onDelete: Cascade)
  optionId      Int
  option        VendorOption @relation(fields: [optionId], references: [id])

  surcharge   Decimal? // Override surcharge amount (null = use default)
  isAvailable Boolean  @default(true) // false = this option is N/A for this style
  isStandard  Boolean  @default(false) // true = included at no extra charge
  notes       String? // e.g., "Small nails only, around top & on base"

  created DateTime  @default(now())
  updated DateTime? @updatedAt

  @@unique([vendorStyleId, optionId])
  @@index([vendorStyleId])
}

// ---------------------------------------------------------------------------
// VENDOR PROGRAMS
//
// Some vendors offer named programs with different pricing rules:
// American Leather Preferred, CR Laine Simplicity, Pom Pom Elite tiers, etc.
// ---------------------------------------------------------------------------

model VendorProgram {
  id             Int            @id @default(autoincrement())
  vendorId       Int
  vendor         Vendor         @relation(fields: [vendorId], references: [id])
  name           String // e.g., "Simplicity", "Preferred Program", "Elite Gold"
  description    String?
  discountType   SurchargeType? // How the program modifies pricing
  discountValue  Decimal? // e.g., 0.05 for 5% discount
  minOrderValue  Decimal? // Minimum order to qualify
  minAnnualValue Decimal? // Minimum annual spend to qualify
  isActive       Boolean        @default(true)

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([vendorId, name])
}

// ---------------------------------------------------------------------------
// TAXONOMY (Department > Category > Type)
// ---------------------------------------------------------------------------

model Department {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  categories      Category[]
  products        Product[]
  vendorStyles    VendorStyle[]
  buyerDraftItems BuyerDraftItem[]

  productPairingsFrom ProductPairing[] @relation("ProductPairingFrom")
  productPairingsTo   ProductPairing[] @relation("ProductPairingTo")

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

model Category {
  id              Int              @id @default(autoincrement())
  name            String
  departmentId    Int
  department      Department       @relation(fields: [departmentId], references: [id])
  types           Type[]
  labelTemplateId Int?
  labelTemplate   LabelTemplate?   @relation(fields: [labelTemplateId], references: [id])
  trackInventory  Boolean          @default(true)
  accountGroupId  Int?
  accountGroup    AccountGroup?    @relation(fields: [accountGroupId], references: [id])
  products        Product[]
  vendorStyles    VendorStyle[]
  buyerDraftItems BuyerDraftItem[]

  productPairingsFrom ProductPairing[] @relation("ProductPairingFromCat")
  productPairingsTo   ProductPairing[] @relation("ProductPairingToCat")

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([name, departmentId], name: "name_departmentId")
}

model Type {
  id              Int              @id @default(autoincrement())
  name            String
  categoryId      Int
  category        Category         @relation(fields: [categoryId], references: [id])
  products        Product[]
  vendorStyles    VendorStyle[]
  buyerDraftItems BuyerDraftItem[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([name, categoryId], name: "name_categoryId")
}

// ---------------------------------------------------------------------------
// LABELING & PRINTING
// ---------------------------------------------------------------------------

model LabelTemplate {
  id          Int        @id @default(autoincrement())
  name        String
  context     String
  tagSize     String
  zplTemplate String
  categories  Category[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

model Printer {
  id             Int      @id @default(autoincrement())
  name           String
  ipAddress      String
  port           Int      @default(9100)
  location       String?
  tagType        String
  store          String?
  supportedSizes String[]
  currentSize    String?

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

model Upc {
  id        Int     @id @default(autoincrement())
  upc       String  @unique
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  sortOrder Int     @default(0)
  source    String  @default("SYSTEM") // SYSTEM (generated), MANUFACTURER (vendor UPC/EAN), IMPORT (legacy)

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

// ---------------------------------------------------------------------------
// AUTHENTICATION & USER MANAGEMENT
// ---------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  unidentifiedScans  UnidentifiedScan[]
  inventoryCounts    PhysicalInventoryCount[]
  reconciliations    Reconciliation[]
  receivingRecords   ReceivingRecord[]
  inventoryTransfers InventoryTransfer[]
  staffMember        StaffMember?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ---------------------------------------------------------------------------
// CUSTOMER & MAILCHIMP
// ---------------------------------------------------------------------------

model Customer {
  id        Int     @id @default(autoincrement())
  firstName String?
  lastName  String?
  email     String? @unique
  phone     String?

  taxExempt            Boolean          @default(false)
  taxExemptReasonId    Int?
  taxExemptReason      TaxExemptReason? @relation(fields: [taxExemptReasonId], references: [id])
  defaultTaxDistrictId Int?
  defaultTaxDistrict   TaxDistrict?     @relation(fields: [defaultTaxDistrictId], references: [id])

  creditBalance      Decimal    @default(0)
  // Stored running AR balance, atomically maintained by `lib/customerLedger.ts`.
  // Phase 0.5 introduces this column populated by a one-time backfill (0.5.3)
  // from the Payment + SalesOrder + OrderLineItem chain. Going forward every
  // SALE / PAYMENT / REFUND atomically appends a CustomerLedgerEntry AND
  // bumps this running total inside the same `prisma.$transaction()`. Daily
  // reconciliation cron (0.5.5) re-derives the balance from source-of-truth
  // and alerts on drift > $0.01. NULL during backfill, then non-null forever.
  openArBalance      Decimal?   @default(0)
  isTradeAccount     Boolean    @default(false)
  tradeCompanyName   String?
  tradeTierId        Int?
  tradeTier          TradeTier? @relation(fields: [tradeTierId], references: [id])
  taxExemptNumber    String?
  customerLevel      Int?
  peakCustomerLevel  Int?
  customerGroup      String?
  lifetimeSpend      Decimal?   @default(0)
  lifetimeOrderCount Int?       @default(0)
  firstOrderDate     DateTime?
  lastOrderDate      DateTime?
  departmentCount    Int?       @default(0)

  // Set by lib/mailchimpAudienceSync.ts after a successful upsert into the
  // configured Mailchimp audience. Cron at scripts/auto-mailchimp-customer-sync.sh
  // ignores customers where this is non-null. Backfill cutoff lives in the
  // runner (AUDIENCE_BACKFILL_CUTOFF) so old customers are not retroactively
  // emailed a confirmation.
  mailchimpSyncedAt DateTime?

  addresses         CustomerAddress[]
  externalIds       CustomerExternalId[]
  salesOrders       SalesOrder[]
  primaryDesignerId Int?
  primaryDesigner   StaffMember?         @relation("PrimaryDesigner", fields: [primaryDesignerId], references: [id])

  mailchimpActivities MailchimpActivity[]
  campaignTargets     CampaignTarget[]
  creditTransactions  CustomerCreditTransaction[]
  ledgerEntries       CustomerLedgerEntry[]
  payments            Payment[]                   @relation("CustomerPayments")
  invoices            Invoice[]                   @relation("CustomerInvoices")
  serviceCases        ServiceCase[]
  interactions        CustomerInteraction[]
  returns             Return[]
  serviceAppointments ServiceAppointment[]
  leads               Lead[]
  windfallEnrichment  WindfallEnrichment?
  proposals           Proposal[]
  tickets             Ticket[]
  timeEntries         TimeEntry[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

model CustomerAddress {
  id         Int      @id @default(autoincrement())
  customerId Int
  label      String?
  address1   String
  address2   String?
  city       String
  state      String
  zip        String
  notes      String?
  customer   Customer @relation(fields: [customerId], references: [id])

  deliveryOrders      SalesOrder[]         @relation("DeliveryAddress")
  returnPickups       Return[]
  serviceAppointments ServiceAppointment[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

model CustomerExternalId {
  id         Int      @id @default(autoincrement())
  externalId String   @unique
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])

  created   DateTime @default(now())
  createdBy String?
}

// Windfall wealth enrichment data, refreshed weekly via CSV import.
// 1:1 with Customer, keyed on customerId. Upserted on each import.
model WindfallEnrichment {
  id         Int      @id @default(autoincrement())
  customerId Int      @unique
  customer   Customer @relation(fields: [customerId], references: [id])

  windfallId      String?  @unique
  matchConfidence Decimal?

  // Wealth
  netWorth               Int?
  netWorthLow            Int?
  netWorthHigh           Int?
  wealthTier             String?
  netWorthLastCalculated DateTime?

  // Life event signals
  recentMover         Boolean @default(false)
  recentlyDivorced    Boolean @default(false)
  recentDeathInFamily Boolean @default(false)
  moneyInMotion       Boolean @default(false)
  liquidityTrigger    Boolean @default(false)
  recentMortgage      Boolean @default(false)

  // Asset signals
  boatOwner           Boolean @default(false)
  planeOwner          Boolean @default(false)
  multiPropertyOwner  Boolean @default(false)
  rentalPropertyOwner Boolean @default(false)
  smallBusinessOwner  Boolean @default(false)
  cryptoInterest      Boolean @default(false)

  // Philanthropy signals
  philanthropicGiver    Boolean @default(false)
  topPhilanthropicDonor Boolean @default(false)
  nonprofitBoardMember  Boolean @default(false)
  donorAdvisedFunds     Boolean @default(false)
  nteeCodes             String?
  regionalFocus         String?
  foundationAssociation Boolean @default(false)
  foundationOfficer     Boolean @default(false)

  // Political signals
  politicalDonor    Boolean @default(false)
  topPoliticalDonor Boolean @default(false)
  politicalParty    String?

  // Financial signals
  hasHouseholdDebt   Boolean  @default(false)
  primaryPropertyLtv Decimal?
  trustAssociation   Boolean  @default(false)

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@index([wealthTier])
}

model MailchimpActivity {
  id         Int      @id @default(autoincrement())
  customerId Int?
  email      String
  campaignId String
  action     String
  timestamp  DateTime
  // DB-insert time (as opposed to `timestamp`, which is when Mailchimp
  // recorded the open/click). Needed by the lead-ingestion job so it
  // can process activity newly inserted since the previous run, even
  // when the underlying Mailchimp event is older (e.g. historical
  // backfills). Indexed for the `created > sinceTimestamp` query.
  created    DateTime @default(now())

  customer Customer?         @relation(fields: [customerId], references: [id])
  campaign MailchimpCampaign @relation(fields: [campaignId], references: [id])

  @@unique([email, campaignId, action, timestamp])
  @@index([created])
}

model MailchimpCampaign {
  id                   String                  @id
  name                 String?
  subject              String?
  sentAt               DateTime?
  // When we last asked Mailchimp for this campaign's email-activity
  // (opens/clicks). The incremental activity backfill reads this to skip
  // campaigns it has already tried, even if Mailchimp returned zero
  // activity rows. Without this the backfill loops forever on empty
  // campaigns (bug seen 2026-04-24 -- stuck at "751 remaining" because
  // every chunk re-processed the same empty campaigns).
  activityLastSyncedAt DateTime?
  activities           MailchimpActivity[]
  stats                MailchimpCampaignStats?
}

model MailchimpCampaignStats {
  id           Int               @id @default(autoincrement())
  campaignId   String            @unique
  emailsSent   Int
  opens        Int
  uniqueOpens  Int
  clicks       Int
  uniqueClicks Int
  bounces      Int
  unsubscribed Int
  lastUpdated  DateTime
  campaign     MailchimpCampaign @relation(fields: [campaignId], references: [id])
}

// Campaign send log for the /reports/opportunities hub. One row per
// (tile, customer, send event). Used by the hub to:
//   1. Show "last sent N days ago" on each tile
//   2. Dedup the drill list -- customers sent this tile within the last
//      30 days are hidden by default so managers don't re-email them
// No historical backfill: we start logging the day Ship 2 deploys.
model CampaignTarget {
  id         Int      @id @default(autoincrement())
  tileId     String
  customerId Int
  customer   Customer @relation(fields: [customerId], references: [id])
  sentAt     DateTime @default(now())
  sentBy     String? // session email of the user who clicked "Mark as sent"
  notes      String?

  @@index([tileId, sentAt(sort: Desc)])
  @@index([customerId, tileId, sentAt(sort: Desc)])
}

// Configurable "bought X, should buy Y" rules that power the Missing
// Pieces tile on the Opportunities hub (Ship 3). Each row defines one
// pairing: a customer who bought a product in `from` but never one in
// `to` within the window is flagged as a cross-sell opportunity.
// Hardcoding pairings would rot with the merchandise mix, so an admin
// page at /admin/setup/product-pairings edits this table directly.
model ProductPairing {
  id               Int        @id @default(autoincrement())
  name             String
  description      String?
  fromDepartmentId Int
  fromDepartment   Department @relation("ProductPairingFrom", fields: [fromDepartmentId], references: [id])
  fromCategoryId   Int?
  fromCategory     Category?  @relation("ProductPairingFromCat", fields: [fromCategoryId], references: [id])
  toDepartmentId   Int
  toDepartment     Department @relation("ProductPairingTo", fields: [toDepartmentId], references: [id])
  toCategoryId     Int?
  toCategory       Category?  @relation("ProductPairingToCat", fields: [toCategoryId], references: [id])
  windowDays       Int        @default(60)
  isActive         Boolean    @default(true)
  sortOrder        Int        @default(0)

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@index([isActive, sortOrder])
}

// Daily / periodic run log for the automated Mailchimp sync + lead
// housekeeping jobs. One row per orchestrator run. Powers the admin
// "last run" banner and the run-history pagination.
model MailchimpSyncLog {
  id                 Int       @id @default(autoincrement())
  runId              String
  kind               String // "mailchimp-sync" | "lead-housekeeping"
  status             String // "SUCCESS" | "PARTIAL" | "FAILED"
  campaignsUpserted  Int       @default(0)
  metricsUpdated     Int       @default(0)
  activitiesInserted Int       @default(0)
  leadsCreated       Int       @default(0)
  leadsUpdated       Int       @default(0)
  leadsArchived      Int       @default(0)
  errors             String[]  @default([])
  startedAt          DateTime
  finishedAt         DateTime?
  created            DateTime  @default(now())

  @@index([kind, created])
  @@index([status])
}

// ---------------------------------------------------------------------------
// INVENTORY MANAGEMENT
// ---------------------------------------------------------------------------

model MonthlySalesPercentage {
  id         Int    @id @default(autoincrement())
  year       Int
  month      String
  percentage Float

  @@unique([year, month], name: "year_month")
}

model SalesGoals {
  id         Int      @id @default(autoincrement())
  year       Int
  goalType   String
  entityName String
  annualGoal Float
  date       DateTime @default(now())

  @@unique([year, goalType, entityName])
}

model PhysicalInventoryCount {
  id            Int      @id @default(autoincrement())
  productId     Int
  product       Product  @relation(fields: [productId], references: [id])
  stockLocation String
  quantity      Int
  countedAt     DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  @@index([countedAt, stockLocation, userId])
}

model InventorySnapshot {
  id            Int      @id @default(autoincrement())
  externalId    Int
  stockLocation String
  quantity      Float
  snapshotDate  DateTime @default(now())

  @@unique([externalId, stockLocation, snapshotDate])
}

model Reconciliation {
  id                 Int      @id @default(autoincrement())
  productId          Int
  product            Product  @relation(fields: [productId], references: [id])
  location           String
  initialExpected    Int
  initialCounted     Int
  initialVariance    Int
  actionTaken        String
  finalCount         Int
  finalVariance      Int
  reconciledAt       DateTime @default(now())
  reconciledByUserId String
  reconciledBy       User     @relation(fields: [reconciledByUserId], references: [id])

  @@unique([productId, location])
}

model UnidentifiedScan {
  id                   Int      @id @default(autoincrement())
  imageUrl             String
  location             String
  notes                String?
  countedAt            DateTime @default(now())
  reconciliationStatus String   @default("PENDING")

  countedByUserId String?
  countedBy       User?   @relation(fields: [countedByUserId], references: [id])

  reconciledProductId Int?
  reconciledProduct   Product?  @relation(fields: [reconciledProductId], references: [id])
  reconciledAt        DateTime?

  @@index([location, reconciliationStatus])
}

// ---------------------------------------------------------------------------
// INVENTORY MOVEMENT (TRANSFERS)
// ---------------------------------------------------------------------------

enum InventoryTransferStatus {
  DRAFT
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum LocationType {
  STORE
  WAREHOUSE
  OFFSITE
}

enum DeliveryMethod {
  TAKEN
  DELIVERY
  PICKUP
}

model StoreLocation {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  code      String       @unique
  type      LocationType
  address   String?
  city      String?
  state     String?
  zip       String?
  isActive  Boolean      @default(true)
  sortOrder Int          @default(0)

  // Maps to the POS's stock location strings for linking imported data
  externalLocationName String? @unique

  defaultReceivingStockLocationId Int?
  defaultReceivingStockLocation   StockLocation? @relation("DefaultReceivingLocation", fields: [defaultReceivingStockLocationId], references: [id])

  stockLocations      StockLocation[]
  registers           Register[]
  inventoryPositions  InventoryPosition[]
  transfersFrom       InventoryTransfer[]  @relation("TransferFrom")
  transfersTo         InventoryTransfer[]  @relation("TransferTo")
  receivingRecords    ReceivingRecord[]
  pickupOrders        SalesOrder[]         @relation("PickupLocation")
  activeStaff         StaffMember[]        @relation("ActiveStaff")
  returnsReceived     Return[]             @relation("ReturnReceivedAt")
  returnsRestocked    Return[]             @relation("ReturnRestockedAt")
  serviceAppointments ServiceAppointment[] @relation("AppointmentStore")

  // Reverse relations for legacy string-to-FK bridge
  orders                   SalesOrder[]              @relation("OrderStore")
  payments                 Payment[]                 @relation("PaymentStore")
  shifts                   StaffShift[]              @relation("ShiftStore")
  boardEntries             UpBoardEntry[]            @relation("BoardStore")
  journalEntries           JournalEntry[]            @relation("JournalStore")
  serviceCases             ServiceCase[]             @relation("CaseStore")
  interactions             CustomerInteraction[]     @relation("InteractionStore")
  consignmentItems         ConsignmentItem[]         @relation("ConsignmentLocation")
  pickItemsFromStore       PickListItem[]            @relation("PickFromStore")
  inventoryFreezeItems     InventoryFreezeItem[]
  buyerDraftPurchaseOrders BuyerDraftPurchaseOrder[]
  trafficSnapshots         TrafficSnapshot[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

model StockLocation {
  id              Int           @id @default(autoincrement())
  storeLocationId Int
  storeLocation   StoreLocation @relation(fields: [storeLocationId], references: [id])
  code            String
  name            String
  description     String?
  building        String?
  floor           Int?
  area            Int?
  locationType    String        @default("STOCK") // FLOOR or STOCK
  squareFootage   Int?
  locationAliases String[] // the POS location names that map to this USL
  isActive        Boolean       @default(true)
  sortOrder       Int           @default(0)

  inventoryPositions InventoryPosition[]
  transfersFrom      InventoryTransfer[] @relation("StockTransferFrom")
  transfersTo        InventoryTransfer[] @relation("StockTransferTo")
  receivingRecords   ReceivingRecord[]
  defaultForStores   StoreLocation[]     @relation("DefaultReceivingLocation")
  pickItemsFrom      PickListItem[]      @relation("PickFrom")
  pickItemsTo        PickListItem[]      @relation("PickTo")
  buyerDraftItems    BuyerDraftItem[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([storeLocationId, code])
}

model InventoryPosition {
  id              Int            @id @default(autoincrement())
  productId       Int
  product         Product        @relation(fields: [productId], references: [id])
  storeLocationId Int
  storeLocation   StoreLocation  @relation(fields: [storeLocationId], references: [id])
  stockLocationId Int?
  stockLocation   StockLocation? @relation(fields: [stockLocationId], references: [id])
  quantity        Int            @default(1)
  salesOrderId    Int?
  salesOrder      SalesOrder?    @relation(fields: [salesOrderId], references: [id])
  notes           String?

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@unique([productId, storeLocationId, stockLocationId, salesOrderId])
}

model DeliveryZone {
  id           Int                  @id @default(autoincrement())
  name         String               @unique
  description  String?
  baseFee      Decimal              @default(0)
  perPieceFee  Decimal?
  isThirdParty Boolean              @default(false)
  carrierName  String?
  isActive     Boolean              @default(true)
  sortOrder    Int                  @default(0)
  zipCodes     DeliveryZoneZip[]
  appointments ServiceAppointment[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

model DeliveryZoneZip {
  id             Int          @id @default(autoincrement())
  deliveryZoneId Int
  deliveryZone   DeliveryZone @relation(fields: [deliveryZoneId], references: [id])
  zipCode        String

  @@unique([deliveryZoneId, zipCode])
}

model InventoryTransfer {
  id                  Int                     @id @default(autoincrement())
  productId           Int
  product             Product                 @relation(fields: [productId], references: [id])
  quantity            Int
  fromLocation        String
  toLocation          String
  fromLocationId      Int?
  fromStoreLocation   StoreLocation?          @relation("TransferFrom", fields: [fromLocationId], references: [id])
  fromStockLocationId Int?
  fromStockLocation   StockLocation?          @relation("StockTransferFrom", fields: [fromStockLocationId], references: [id])
  toLocationId        Int?
  toStoreLocation     StoreLocation?          @relation("TransferTo", fields: [toLocationId], references: [id])
  toStockLocationId   Int?
  toStockLocation     StockLocation?          @relation("StockTransferTo", fields: [toStockLocationId], references: [id])
  notes               String?
  requestedByUserId   String
  status              InventoryTransferStatus @default(DRAFT)
  requestedByUser     User                    @relation(fields: [requestedByUserId], references: [id])
  shippedAt           DateTime?
  receivedAt          DateTime?
  receivedByUserId    String?

  created DateTime  @default(now())
  updated DateTime? @updatedAt

  @@index([fromLocation, toLocation])
  @@index([fromLocationId, toLocationId])
  @@index([status])
}

// ---------------------------------------------------------------------------
// PURCHASING & RECEIVING
// ---------------------------------------------------------------------------

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  CONFIRMED
  RECEIVED_PARTIAL
  RECEIVED_FULL
  SHORT_CLOSED
  CANCELLED
}

model PurchaseOrder {
  id                Int                 @id @default(autoincrement())
  poNumber          String              @unique
  vendorId          Int
  vendor            Vendor              @relation(fields: [vendorId], references: [id])
  salesOrderId      Int?
  salesOrder        SalesOrder?         @relation(fields: [salesOrderId], references: [id])
  orderDate         DateTime            @default(now())
  expectedDelivery  DateTime?
  estimatedShipDate DateTime?
  status            PurchaseOrderStatus @default(DRAFT)
  vendorAckNumber   String?
  vendorAckDate     DateTime?
  notes             String?
  // Stamped by the legacy-POS inbound-items import (a full snapshot of open
  // POs): a PO absent from the latest export was received/cancelled upstream,
  // so inbound dashboards filter to MAX(lastSeenInInboundExport).
  lastSeenInInboundExport DateTime?

  // Vendor return support (negative PO)
  isReturn        Boolean @default(false)
  returnId        Int?
  customerReturn  Return? @relation(fields: [returnId], references: [id])
  vendorReference String? // Vendor's RMA/credit memo number

  lineItems               PurchaseOrderItem[]
  receivingRecords        ReceivingRecord[]
  linkedTasks             ServiceTask[]            @relation("TaskLinkedPO")
  // Imported customer-service cases that reference this PO. Mirrors
  // linkedTasks above — cases via ServiceCase.purchaseOrderId, tasks
  // via ServiceTask.linkedPurchaseOrderId.
  serviceCases            ServiceCase[]            @relation("ServiceCasePO")
  consignmentPaymentBatch ConsignmentPaymentBatch?
  // Buyer-draft link back-relation (Slice 6.14, 2026-05-22). At most one
  // BuyerDraftPoRealPoLink per real PO (enforced by `@unique` on
  // `realPoId` of the join table). Replaces the prior 1:1 shape from
  // Slice 6.13 — see `BuyerDraftPoRealPoLink` for the M:N rationale.
  buyerDraftLink          BuyerDraftPoRealPoLink?

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

model PurchaseOrderItem {
  id              Int     @id @default(autoincrement())
  purchaseOrderId Int
  productId       Int?
  orderLineItemId Int?
  orderedQuantity Decimal @default(0)
  unitCost        Decimal @default(0)

  externalPorNo String? @unique
  partNo        String?
  productName   String?

  // For apparel: link to the specific size/color variant
  productVariantId Int?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])

  // Reference to the VendorStyle used to configure this item (if applicable)
  vendorStyleId Int?
  vendorStyle   VendorStyle? @relation(fields: [vendorStyleId], references: [id])

  // For configurable products: capture the selected options at time of order
  selectedGrade   String? // e.g., "Grade 20" or "Maple"
  selectedFinish  String? // e.g., "Renaissance"
  selectedOptions String? // JSON string of selected option codes and surcharges

  purchaseOrder    PurchaseOrder     @relation(fields: [purchaseOrderId], references: [id])
  product          Product?          @relation(fields: [productId], references: [id])
  orderLineItem    OrderLineItem?    @relation(fields: [orderLineItemId], references: [id])
  receivingRecords ReceivingRecord[]

  @@index([orderLineItemId])
}

model ReceivingRecord {
  id                  Int      @id @default(autoincrement())
  purchaseOrderItemId Int
  purchaseOrderId     Int
  quantityReceived    Decimal  @default(0)
  receivedDate        DateTime @default(now())
  receiverUserId      String
  destinationLocation String?

  destinationLocationId      Int?
  destinationStoreLocation   StoreLocation? @relation(fields: [destinationLocationId], references: [id])
  destinationStockLocationId Int?
  destinationStockLocation   StockLocation? @relation(fields: [destinationStockLocationId], references: [id])

  condition   String? // OK, Damaged, Wrong Item, Short
  tagsPrinted Boolean @default(false)

  externalGipNo String?
  externalPorNo String?
  lineCost      Decimal?
  invoiceNumber String?

  purchaseOrderItem PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id])
  purchaseOrder     PurchaseOrder     @relation(fields: [purchaseOrderId], references: [id])
  receiverUser      User              @relation(fields: [receiverUserId], references: [id])

  @@unique([externalGipNo, externalPorNo])
  @@index([receivedDate])
  @@index([purchaseOrderItemId])
