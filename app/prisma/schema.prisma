enum SalesOrderStatus {
  QUOTE
  ORDER
  FULFILLED
  CANCELLED
  RETURNED
}

enum LineItemStatus {
  ACTIVE
  CANCELLED
  BACKORDERED
  REPLACED
}

enum DispatchStatus {
  PO_PLACED
  RECEIVED_IN_WAREHOUSE
  READY_FOR_PICKUP
  SCHEDULED_DELIVERY
  FULFILLED
  CANCELLED
}

model SalesOrder {
  id         Int              @id @default(autoincrement())
  orderno    String           @unique
  orderDate  DateTime?
  status     SalesOrderStatus @default(QUOTE)
  customerId Int?
  customer   Customer?        @relation(fields: [customerId], references: [id])

  salesperson     String?
  salesPersonId   Int?
  salesPerson     StaffMember?   @relation("OrderSalesPerson", fields: [salesPersonId], references: [id])
  splitWithId     Int?
  splitWith       StaffMember?   @relation("SplitSales", fields: [splitWithId], references: [id])
  storeLocation   String?
  storeLocationId Int?
  store           StoreLocation? @relation("OrderStore", fields: [storeLocationId], references: [id])
  totalTax        Decimal?
  totalPaid       Decimal?

  taxDistrictId     Int?
  taxDistrict       TaxDistrict?     @relation(fields: [taxDistrictId], references: [id])
  taxExemptReasonId Int?
  taxExemptReason   TaxExemptReason? @relation(fields: [taxExemptReasonId], references: [id])

  orderNotes      String?
  dispatchStatus  DispatchStatus? @default(PO_PLACED)
  externalCustomerCode String?
  quoteCode       String?
  quoteDate       DateTime?

  deliveryMethod        DeliveryMethod?
  deliveryAddressId     Int?
  deliveryAddress       CustomerAddress? @relation("DeliveryAddress", fields: [deliveryAddressId], references: [id])
  pickupLocationId      Int?
  pickupLocation        StoreLocation?   @relation("PickupLocation", fields: [pickupLocationId], references: [id])
  scheduledDeliveryDate DateTime?
  deliveryNotes         String?

  lineItems           OrderLineItem[]
  invoices            Invoice[]
  payments            Payment[]
  purchaseOrders      PurchaseOrder[]
  inventoryPositions  InventoryPosition[]
  creditTransactions  CustomerCreditTransaction[]
  ledgerEntries       CustomerLedgerEntry[]
  serviceCases        ServiceCase[]
  interactions        CustomerInteraction[]
  changeLogs          OrderChangeLog[]
  returns             Return[]
  exchangeReturns     Return[]                    @relation("ExchangeOrder")
  serviceAppointments ServiceAppointment[]
  pickLists           PickList[]
  consignmentItems    ConsignmentItem[]
  leads               Lead[]
  linkedTasks         ServiceTask[]               @relation("TaskLinkedOrder")
  proposal            Proposal?

  // Pipeline archiving — set when a quote is marked lost/closed; clearable to restore
  pipelineArchivedAt DateTime?
  pipelineNote       String?

  // When a quote is archived as a duplicate or outdated version, link to the
  // quote that replaces it. The replacement stays in the pipeline; the archived
  // quote is excluded from conversion-rate denominators and pipeline counts.
  archiveReason     String? // "Updated Quote" | "Duplicate" | "Customer Passed" | "Stale" | "Other"
  replacedByOrderId Int?
  replacedByOrder   SalesOrder?  @relation("OrderReplacement", fields: [replacedByOrderId], references: [id], onDelete: SetNull)
  replacementFor    SalesOrder[] @relation("OrderReplacement")

  // When TRUE, runSalesImport's same-day-rewrite cleanup heuristic is
  // skipped for this base order. Used when the rewrite is a price-tweak
  // (customer kept all base items; rewrite only contains the line whose
  // price changed) — the heuristic can't distinguish that case from a
  // genuine drop (the drop-case shape) and would over-cancel base lines.
  // Operator sets this manually when they've verified the order is
  // correct as-is. Added after an OS sales-gap incident.
  // See `lib/sameDayRewriteCleanup.ts` doc-comment for the full pattern.
  skipSameDayRewriteCleanup Boolean @default(false)

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@index([quoteCode])
  @@index([replacedByOrderId])
  @@index([status, orderDate])
}

model OrderLineItem {
  id              Int        @id @default(autoincrement())
  salesOrderId    Int
  salesOrder      SalesOrder @relation(fields: [salesOrderId], references: [id])
  lineNumber      Int? // sequential within order, for idempotent re-import
  partNo          String?
  barcode         String?
  vatRate         Decimal?
  vatAmount       Decimal?
  porNumber       String?
  productName     String?
  orderedQuantity Decimal
  netPrice        Decimal
  cost            Decimal
  productId       Int?
  product         Product?   @relation(fields: [productId], references: [id])

  taxDistrictId Int?
  taxDistrict   TaxDistrict? @relation(fields: [taxDistrictId], references: [id])

  // Reference to the VendorStyle used to configure this item (if applicable)
  vendorStyleId Int?
  vendorStyle   VendorStyle? @relation(fields: [vendorStyleId], references: [id])

  // Source and fulfillment tracking per line item
  source       String? // FLOOR or ORDER
  fulfillment  String? // TAKE, PICKUP, or DELIVERY
  fulfilledQty Decimal? @default(0) // how many have been delivered/picked up/taken

  // For configurable products: what was selected at time of sale
  selectedGrade   String?
  selectedFinish  String?
  selectedOptions String? // JSON string of selected options with prices

  // Line item lifecycle
  lineItemStatus       LineItemStatus @default(ACTIVE)
  cancelReason         String?
  replacedByLineItemId Int?           @unique
  replacedByLineItem   OrderLineItem? @relation("ReplacedBy", fields: [replacedByLineItemId], references: [id])
  replacesLineItem     OrderLineItem? @relation("ReplacedBy")

  purchaseOrderItems  PurchaseOrderItem[]
  invoiceLineItems    InvoiceLineItem[]
  returns             Return[]
  serviceAppointments ServiceAppointment[]
  pickListItems       PickListItem[]

  created DateTime  @default(now())
  updated DateTime? @updatedAt

  @@unique([salesOrderId, lineNumber])
  @@index([productId])
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
}

model Invoice {
  id            Int                   @id @default(autoincrement())
  invoiceNo     String                @unique
  invoiceDate   DateTime
  taxAmount     Decimal
  salesOrderId  Int?
  salesOrder    SalesOrder?           @relation(fields: [salesOrderId], references: [id])
  lineItems     InvoiceLineItem[]
  ledgerEntries CustomerLedgerEntry[]

  // Product-grade AR fields (open-item). customerId/total are nullable for
  // legacy SalesOrder-coupled invoices; the new invoicing flow sets them. AR is
  // recognized when status = ISSUED. See docs/domains/accounts-receivable.md.
  customerId   Int?
  customer     Customer?            @relation("CustomerInvoices", fields: [customerId], references: [id])
  total        Decimal?
  dueDate      DateTime?
  status       InvoiceStatus        @default(DRAFT)
  applications PaymentApplication[]

  // Authoring fields (invoice composer, 2026-06-10). organizationId is set on
  // every authored invoice; legacy imported invoices leave it NULL. issuedAt is
  // the moment AR was recognized (status -> ISSUED + SALE ledger entry + JE).
  organizationId Int?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  notes          String?
  issuedAt       DateTime?
  createdBy      String?
  updatedBy      String?
  payments       Payment[]     @relation("InvoicePayments")

  created DateTime  @default(now())
  updated DateTime? @updatedAt

  @@index([customerId, status])
  @@index([organizationId, status])
}

// Open-item AR: allocates a Payment to a specific Invoice. A payment may split
// across invoices; an invoice may take many applications. The unapplied portion
// of a payment is on-account credit. See docs/domains/accounts-receivable.md.
model PaymentApplication {
  id             Int          @id @default(autoincrement())
  organizationId Int
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  paymentId Int
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  invoiceId Int
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  amountApplied Decimal

  created   DateTime  @default(now())
  createdBy String?

  @@index([invoiceId])
  @@index([paymentId])
  @@index([organizationId])
}

// Two line shapes share this model: legacy delivery lines reference an
// OrderLineItem (orderLineItemId set, freeform fields NULL); authored lines
// are freeform (orderLineItemId NULL, description/quantity/unitPrice/amount
// set). `amount` is the LINE TOTAL (quantity x unitPrice), mirroring the
// OrderLineItem.netPrice convention. Postgres allows many NULL
// orderLineItemId rows under the unique constraint, so freeform lines coexist.
model InvoiceLineItem {
  id                Int            @id @default(autoincrement())
  invoiceId         Int
  invoice           Invoice        @relation(fields: [invoiceId], references: [id])
  orderLineItemId   Int?
  orderLineItem     OrderLineItem? @relation(fields: [orderLineItemId], references: [id])
  deliveredQuantity Decimal        @default(0)

  description String?
  quantity    Decimal?
  unitPrice   Decimal?
  amount      Decimal?
  sortOrder   Int     @default(0)

  @@unique([invoiceId, orderLineItemId], name: "invoiceId_orderLineItemId")
}

enum PaymentStatus {
  PENDING
  COMPLETED
  REFUNDED
  VOIDED
  FAILED
}

enum PaymentMethod {
  CASH
  CARD
  CHECK
  GIFT_CARD
  STORE_CREDIT
  WIRE
  ACH
  FINANCE
  OTHER
}

model Payment {
  id              Int            @id @default(autoincrement())
  salesOrderId    Int?
  salesOrder      SalesOrder?    @relation(fields: [salesOrderId], references: [id])
  paymentDate     DateTime
  paymentType     String
  paymentAmount   Decimal
  paymentCode     String?        @unique
  applications    PaymentApplication[]
  storeLocation   String?
  storeLocationId Int?
  store           StoreLocation? @relation("PaymentStore", fields: [storeLocationId], references: [id])

  // Structured payment tracking (nullable for backward compat with imports)
  status PaymentStatus?
  method PaymentMethod?

  // Register and till tracking
  registerId    Int?
  register      Register?    @relation(fields: [registerId], references: [id])
  tillId        Int?
  till          Till?        @relation(fields: [tillId], references: [id])
  staffMemberId Int?
  staffMember   StaffMember? @relation(fields: [staffMemberId], references: [id])
  customerId    Int?
  customer      Customer?    @relation("CustomerPayments", fields: [customerId], references: [id])

  // Payment processor details
  processorType  String?
  processorTxnId String?
  processorData  Json?

  // Card details (last 4 only, safe to store)
  cardLast4 String?
  cardBrand String?

  // Check details
  checkNumber String?

  // Authored-invoice link (invoice authoring, 2026-06-10). Structural binding
  // for invoice payments — the Stripe webhook routes on THIS, never on
  // session metadata alone. Mirrors salesOrderId for order payments.
  invoiceId Int?
  invoice   Invoice? @relation("InvoicePayments", fields: [invoiceId], references: [id])

  // Gift card link
  giftCardId Int?
  giftCard   GiftCard? @relation(fields: [giftCardId], references: [id])

  // Refund tracking
  isRefund          Boolean   @default(false)
  originalPaymentId Int?
  originalPayment   Payment?  @relation("PaymentRefunds", fields: [originalPaymentId], references: [id])
  refundedPayments  Payment[] @relation("PaymentRefunds")
  refundReason      String?

  creditTransactions CustomerCreditTransaction[]
  ledgerEntries      CustomerLedgerEntry[]
  returnRefunds      Return[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@index([salesOrderId])
  @@index([paymentDate])
  @@index([tillId])
  @@index([invoiceId])
}

