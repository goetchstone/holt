// ---------------------------------------------------------------------------
// RETURNS
// ---------------------------------------------------------------------------

enum ReturnStatus {
  INITIATED
  PICKUP_SCHEDULED
  PICKUP_COMPLETED
  RECEIVED
  INSPECTED
  RESTOCKED
  WRITTEN_OFF
  CLOSED
  CANCELLED
}

enum ReturnReason {
  DEFECTIVE
  DAMAGED_IN_DELIVERY
  WRONG_ITEM
  CUSTOMER_CHANGED_MIND
  NOT_AS_DESCRIBED
  DUPLICATE_ORDER
  OTHER
}

enum InspectionCondition {
  LIKE_NEW
  MINOR_DAMAGE
  MAJOR_DAMAGE
  UNSALVAGEABLE
}

model Return {
  id           Int          @id @default(autoincrement())
  returnNumber String       @unique
  status       ReturnStatus @default(INITIATED)
  reason       ReturnReason
  reasonNotes  String?

  // Original sale
  salesOrderId Int
  salesOrder   SalesOrder     @relation(fields: [salesOrderId], references: [id])
  lineItemId   Int?
  lineItem     OrderLineItem? @relation(fields: [lineItemId], references: [id])

  // Customer
  customerId Int?
  customer   Customer? @relation(fields: [customerId], references: [id])

  // Product snapshot
  productId   Int?
  product     Product? @relation(fields: [productId], references: [id])
  productName String?
  partNo      String?
  quantity    Int      @default(1)

  // Pickup scheduling
  pickupRequired  Boolean          @default(false)
  pickupAddressId Int?
  pickupAddress   CustomerAddress? @relation(fields: [pickupAddressId], references: [id])
  pickupDate      DateTime?
  pickupTimeSlot  String?
  pickupNotes     String?

  // Receiving
  receivedAt         DateTime?
  receivedById       Int?
  receivedBy         StaffMember?   @relation("ReturnReceivedBy", fields: [receivedById], references: [id])
  receivedLocationId Int?
  receivedLocation   StoreLocation? @relation("ReturnReceivedAt", fields: [receivedLocationId], references: [id])

  // Inspection
  inspectedAt         DateTime?
  inspectedById       Int?
  inspectedBy         StaffMember?         @relation("ReturnInspectedBy", fields: [inspectedById], references: [id])
  inspectionCondition InspectionCondition?
  inspectionNotes     String?

  // Disposition
  restockedAt         DateTime?
  restockedLocationId Int?
  restockedLocation   StoreLocation? @relation("ReturnRestockedAt", fields: [restockedLocationId], references: [id])
  writeOffReason      String?

  // Refund (uses existing payment system)
  refundPaymentId Int?
  refundPayment   Payment? @relation(fields: [refundPaymentId], references: [id])
  refundAmount    Decimal?

  // Exchange (linked replacement order)
  exchangeOrderId Int?
  exchangeOrder   SalesOrder? @relation("ExchangeOrder", fields: [exchangeOrderId], references: [id])

  // Vendor return POs created from this return
  vendorReturnPOs PurchaseOrder[]

  // Customer portal
  portalToken       String?   @unique
  portalRequestedAt DateTime?
  customerNotes     String?

  // Shipping
  returnShippingMethod String?
  returnTrackingNumber String?

  // Audit
  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?

  @@index([status])
  @@index([salesOrderId])
  @@index([customerId])
  @@index([pickupDate])
}

