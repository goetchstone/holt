  proposalNumber String         @unique
  status         ProposalStatus @default(DRAFT)
  customerId     Int?
  customer       Customer?      @relation(fields: [customerId], references: [id])

  projectName String?
  companyName String?

  coverLetter   String?
  terms         String?
  internalNotes String?

  salesPersonId Int?
  salesPerson   StaffMember? @relation("ProposalSalesPerson", fields: [salesPersonId], references: [id])

  salesOrderId Int?        @unique
  salesOrder   SalesOrder? @relation(fields: [salesOrderId], references: [id])
  sentAt       DateTime?
  acceptedAt   DateTime?
  expiresAt    DateTime?

  lineItems ProposalLineItem[]

  created   DateTime  @default(now())
  updated   DateTime? @updatedAt
  createdBy String?
  updatedBy String?
}

model ProposalLineItem {
  id         Int      @id @default(autoincrement())
  proposalId Int
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  sortOrder  Int      @default(0)

  type          String       @default("CUSTOM")
  productId     Int?
  product       Product?     @relation(fields: [productId], references: [id])
  vendorStyleId Int?
  vendorStyle   VendorStyle? @relation("ProposalVendorStyle", fields: [vendorStyleId], references: [id])

  itemName        String
  itemDescription String?
  vendorName      String?
  partNumber      String?

  cost        Decimal
  retailPrice Decimal
  quantity    Int     @default(1)

  selectedGrade   String?
