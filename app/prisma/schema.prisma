enum CreditTransactionType {
  REFUND_CREDIT
  USAGE
  ADJUSTMENT
}

model CustomerCreditTransaction {
  id            Int                   @id @default(autoincrement())
  customerId    Int
  customer      Customer              @relation(fields: [customerId], references: [id])
  type          CreditTransactionType
  amount        Decimal
  balanceBefore Decimal
  balanceAfter  Decimal
  paymentId     Int?
  payment       Payment?              @relation(fields: [paymentId], references: [id])
  salesOrderId  Int?
  salesOrder    SalesOrder?           @relation(fields: [salesOrderId], references: [id])
  reference     String?
  notes         String?

  created   DateTime @default(now())
  createdBy String?

  @@index([customerId])
  @@index([created])
}

// AR ledger (Phase 0.5). One row per money-affecting event per customer.
//
// Mirrors CustomerCreditTransaction's shape — same balanceBefore /
// balanceAfter snapshot pattern, same atomic-write contract: every
// `appendEntry()` writes the entry AND bumps `Customer.openArBalance` in
// the same `prisma.$transaction()`. Reconstructible from source data, but
// once written it's the system-of-record for AR (faster than re-reducing
// all payments + line items per page-load, and survives the POS import
// timing gaps that historically caused customer-page balance jitter).
//
// Sign convention (matches CustomerCreditTransaction):
//   amount > 0 increases balance owed (SALE, ADJUSTMENT_DEBIT)
//   amount < 0 decreases balance owed (PAYMENT, REFUND_ISSUED, ADJUSTMENT_CREDIT)
//   DEPOSIT_RECEIVED is amount > 0 (a deposit creates an offsetting debit
//   to the customer that nets when invoicing happens — same shape as a
//   sale for the running-balance math)
//   DEPOSIT_APPLIED is amount < 0 (consumes the deposit when invoiced)
//
// Source-of-truth references (salesOrderId / paymentId / invoiceId) are
// nullable because some entries (manual ADJUSTMENT) have no source row.
// Reports use these to drill back to the originating event.
model CustomerLedgerEntry {
  id            Int                     @id @default(autoincrement())
  customerId    Int
  customer      Customer                @relation(fields: [customerId], references: [id])
  type          CustomerLedgerEntryType
  amount        Decimal
  balanceBefore Decimal
  balanceAfter  Decimal

  salesOrderId Int?
  salesOrder   SalesOrder? @relation(fields: [salesOrderId], references: [id])
  paymentId    Int?
  payment      Payment?    @relation(fields: [paymentId], references: [id])
  invoiceId    Int?
  invoice      Invoice?    @relation(fields: [invoiceId], references: [id])

  reference String?
  notes     String?

  created   DateTime @default(now())
  createdBy String?

  @@index([customerId, created])
  @@index([created])
  @@index([salesOrderId])
  @@index([paymentId])
}

enum CustomerLedgerEntryType {
  SALE
  PAYMENT
  REFUND_ISSUED
  DEPOSIT_RECEIVED
  DEPOSIT_APPLIED
  ADJUSTMENT_DEBIT
  ADJUSTMENT_CREDIT
}

